{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ai/framework/contracts/workflow-output-envelope.schema.json",
  "title": "WorkflowOutputPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "artifacts",
    "recommendedNextWorkflowCodes"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "completed",
        "completed-with-open-questions",
        "blocked",
        "failed"
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "artifactType",
          "name"
        ],
        "properties": {
          "artifactType": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "path": {
            "type": ["string", "null"]
          }
        }
      }
    },
    "generatedRequirements": {
      "type": "array",
      "items": {
        "$ref": "requirement.schema.json"
      }
    },
    "generatedBacklogItems": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "order",
          "title",
          "description",
          "workflowCode",
          "priority"
        ],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "workflowCode": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "implementedChanges": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "filesTouched": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "testsExecuted": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "generatedOpenQuestions": {
      "type": "array",
      "items": {
        "$ref": "open-question.schema.json"
      }
    },
    "generatedDecisions": {
      "type": "array",
      "items": {
        "$ref": "decision.schema.json"
      }
    },
    "documentationUpdates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "knowledgeUpdates": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "recommendedNextWorkflowCodes": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
