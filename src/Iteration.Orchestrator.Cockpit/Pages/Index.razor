@page "/"
@using System.Net.Http.Json
@using Iteration.Orchestrator.Cockpit.Models
@inject IHttpClientFactory HttpClientFactory
@implements IDisposable
@inject Iteration.Orchestrator.Cockpit.Services.SelectedSolutionState SelectedSolutionState

<PageTitle>Cockpit</PageTitle>

<style>
    .cockpit-shell {
        display: flex;
        flex-direction: column;
        gap: 18px;
    }

    .cockpit-toolbar {
        background: #fff;
        border: 1px solid #eceff3;
        border-radius: 18px;
        padding: 14px 16px;
        box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
    }

    .cockpit-board {
        background: linear-gradient(180deg, #ffffff 0%, #fbfcfe 100%);
        border: 1px solid #eceff3;
        border-radius: 22px;
        box-shadow: 0 18px 45px rgba(15, 23, 42, 0.05);
        overflow-x: auto;
    }

    .pipeline-grid {
        min-width: 1500px;
    }

    .pipeline-header,
    .pipeline-row {
        display: grid;
        grid-template-columns: 270px repeat(8, 180px);
        gap: 12px;
        align-items: start;
    }

    .pipeline-header {
        padding: 18px 18px 12px 18px;
        position: sticky;
        top: 0;
        z-index: 1;
        background: rgba(255,255,255,0.96);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid #eef2f7;
    }

    .pipeline-row {
        padding: 14px 18px;
        border-top: 1px solid #f2f4f8;
    }

    .pipeline-column-title {
        font-size: 0.82rem;
        font-weight: 700;
        color: #334155;
        letter-spacing: 0.02em;
        text-transform: uppercase;
    }

    .pipeline-column-subtitle {
        font-size: 0.72rem;
        color: #94a3b8;
        margin-top: 4px;
    }

    .lane-cell {
        min-height: 92px;
        display: flex;
        align-items: stretch;
    }

    .lane-placeholder {
        width: 100%;
        border: 1px dashed #e7ebf1;
        border-radius: 16px;
        background: rgba(248, 250, 252, 0.72);
    }

    .stage-card {
        width: 100%;
        background: #fff;
        border: 1px solid #e8edf4;
        border-radius: 16px;
        padding: 10px 12px;
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.04);
        cursor: pointer;
        transition: transform 0.14s ease, box-shadow 0.14s ease, border-color 0.14s ease;
    }

        .stage-card:hover {
            transform: translateY(-1px);
            box-shadow: 0 12px 26px rgba(15, 23, 42, 0.08);
            border-color: #cbd5e1;
        }

    .requirement-card {
        background: linear-gradient(180deg, #ffffff 0%, #f8fbff 100%);
    }

    .card-date {
        font-size: 0.72rem;
        color: #94a3b8;
        margin-bottom: 6px;
    }

    .card-title {
        font-size: 0.88rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.25;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        min-height: 2.2em;
    }

    .card-status {
        margin-top: 10px;
        font-size: 0.74rem;
        color: #64748b;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 999px;
        flex: none;
    }

    .board-empty {
        padding: 48px 24px;
        text-align: center;
        color: #64748b;
    }

    .toolbar-title {
        font-size: 1.45rem;
        font-weight: 700;
        color: #0f172a;
    }

    .toolbar-subtitle {
        color: #64748b;
        font-size: 0.92rem;
    }

    .drawer-section {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .drawer-content-block {
        border: 1px solid #e8edf4;
        border-radius: 16px;
        padding: 14px;
        background: #fff;
    }

    .doc-pre {
        white-space: pre-wrap;
        word-break: break-word;
        margin: 0;
        font-family: Consolas, 'Courier New', monospace;
        font-size: 0.82rem;
        color: #334155;
    }
</style>

<div class="cockpit-shell">
    <MudPaper Class="cockpit-toolbar" Elevation="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Wrap="Wrap.Wrap" Spacing="2">
           
            <MudStack Row="true" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="2">
                <MudSelect T="Guid?"
                           Value="_selectedSolutionId"
                           ValueChanged="OnSolutionSelectionChangedAsync"
                           Label="Solution"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Style="min-width:320px; background:#fff;">
                    @foreach (var solution in _solutions)
                    {
                        <MudSelectItem T="Guid?" Value="@solution.SolutionId">@solution.Name (@solution.Code)</MudSelectItem>
                    }
                </MudSelect>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="OpenCreateSolutionDialog">
                    Create solution
                </MudButton>

                <MudMenu Dense="true" Disabled="SelectedSolutionState.Current is null || _documentsLoading" Color="Color.Default" Variant="Variant.Outlined" StartIcon="@Icons.Material.Filled.Description" Label="Documentation">
                    @if (_documentsLoading)
                    {
                        <MudMenuItem Disabled="true">Loading documents...</MudMenuItem>
                    }
                    else if (_documents.Count == 0)
                    {
                        <MudMenuItem Disabled="true">No SDLC documents found</MudMenuItem>
                    }
                    else
                    {
                        @foreach (var document in _documents)
                        {
                            <MudMenuItem OnClick="() => OpenDocumentAsync(document)">@document.Name</MudMenuItem>
                        }
                    }
                </MudMenu>
            </MudStack>
        </MudStack>
    </MudPaper>

    @if (_loading)
    {
        <MudPaper Class="pa-8" Elevation="0">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Typo="Typo.body2">Loading cockpit...</MudText>
            </MudStack>
        </MudPaper>
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_loadError</MudAlert>
    }
    else if (SelectedSolutionState.Current is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
            Create or select a solution to load the workflow cockpit.
        </MudAlert>
    }
    else
    {
        <MudPaper Class="cockpit-board" Elevation="0">
            <div class="pipeline-grid">
                <div class="pipeline-header">
                    @foreach (var lane in _lanes)
                    {
                        <div>
                            <div class="pipeline-column-title">@lane.Title</div>
                            <div class="pipeline-column-subtitle">@lane.Subtitle</div>
                        </div>
                    }
                </div>

                @if (_requirements.Count == 0)
                {
                    <div class="board-empty">
                        No requirements exist yet for the selected solution.
                    </div>
                }
                else
                {
                    @foreach (var requirement in _requirements)
                    {
                        var row = BuildRow(requirement);
                        <div class="pipeline-row">
                            @foreach (var lane in _lanes)
                            {
                                <div class="lane-cell">
                                    @if (row.TryGetValue(lane.Key, out var card))
                                    {
                                        <div class="stage-card @(lane.Key == LaneKeys.Requirement ? "requirement-card" : string.Empty)"
                                             @onclick="() => OpenCard(card)">
                                            <div class="card-date">@card.DisplayDate</div>
                                            <div class="card-title">@card.Title</div>
                                            <div class="card-status">
                                                <span class="status-dot" style="background:@card.StatusColor;"></span>
                                                <span>@card.StatusLabel</span>
                                            </div>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="lane-placeholder"></div>
                                    }
                                </div>
                            }
                        </div>
                    }
                }
            </div>
        </MudPaper>
    }
</div>

<MudDrawer @bind-Open="_drawerOpen" Anchor="Anchor.End" Variant="DrawerVariant.Temporary" Elevation="1" Width="520px">
    <MudStack Class="pa-4 drawer-section">
        @if (_activeDocument is not null)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">@_activeDocument.Name</MudText>
                    <MudText Typo="Typo.caption">@_activeDocument.RelativePath</MudText>
                </MudStack>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseDrawer" />
            </MudStack>

            <MudPaper Class="drawer-content-block" Elevation="0">
                <MudText Typo="Typo.caption" Class="mb-2">Last updated @(_activeDocument.LastModifiedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</MudText>
                <pre class="doc-pre">@_activeDocument.Content</pre>
            </MudPaper>
        }
        else if (_activeCard is not null)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">@_activeCard.Title</MudText>
                    <MudText Typo="Typo.caption">@_activeCard.LaneTitle</MudText>
                </MudStack>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseDrawer" />
            </MudStack>

            <MudPaper Class="drawer-content-block" Elevation="0">
                <MudText Typo="Typo.caption" Class="mb-1">Created @(_activeCard.Requirement.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</MudText>
                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" Style=@($"border-color:{_activeCard.StatusColor}; color:{_activeCard.StatusColor};")>
                    @_activeCard.StatusLabel
                </MudChip>
                <MudText Typo="Typo.body2" Class="mt-3">@_activeCard.Description</MudText>
            </MudPaper>

            <MudPaper Class="drawer-content-block" Elevation="0">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Actions</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Disabled="!CanAnalyze(_activeCard.Requirement.Status) || _runningRequirementId == _activeCard.Requirement.Id" OnClick="() => StartAnalyzeAsync(_activeCard.Requirement.Id)">
                        Analyze
                    </MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" Disabled="!CanDesign(_activeCard.Requirement.Status) || _runningRequirementId == _activeCard.Requirement.Id" OnClick="() => StartDesignAsync(_activeCard.Requirement.Id)">
                        Design
                    </MudButton>
                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Disabled="!CanPlan(_activeCard.Requirement.Status) || _runningRequirementId == _activeCard.Requirement.Id" OnClick="() => StartPlanAsync(_activeCard.Requirement.Id)">
                        Plan
                    </MudButton>
                    @if (_activeCard.BacklogItem is not null)
                    {
                        <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" Disabled="!CanImplement(_activeCard.BacklogItem) || _runningBacklogItemId == _activeCard.BacklogItem.Id" OnClick="() => StartImplementationAsync(_activeCard.BacklogItem.Id)">
                            Implement
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>

            <MudPaper Class="drawer-content-block" Elevation="0">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Workflow snapshot</MudText>
                <MudText Typo="Typo.body2">Requirement status: @_activeCard.Requirement.Status</MudText>
                <MudText Typo="Typo.body2">Priority: @_activeCard.Requirement.Priority</MudText>
                @if (_activeCard.WorkflowRun is not null)
                {
                    <MudText Typo="Typo.body2">Workflow: @_activeCard.WorkflowRun.WorkflowCode</MudText>
                    <MudText Typo="Typo.body2">Run stage: @_activeCard.WorkflowRun.CurrentStage</MudText>
                    <MudText Typo="Typo.body2">Run status: @_activeCard.WorkflowRun.Status</MudText>
                }
                @if (_activeCard.BacklogItem is not null)
                {
                    <MudText Typo="Typo.body2">Backlog order: @_activeCard.BacklogItem.PlanningOrder</MudText>
                    <MudText Typo="Typo.body2">Backlog status: @_activeCard.BacklogItem.Status</MudText>
                }
            </MudPaper>
        }
    </MudStack>
</MudDrawer>

@if (_createSolutionDialogOpen)
{
    <MudOverlay Visible="true" DarkBackground="true" AutoClose="false">
        <div style="width:min(760px, calc(100vw - 32px)); margin:48px auto;">
            <MudPaper Class="pa-4" Style="border-radius:20px;" Elevation="8">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">Create / setup solution</MudText>
                    <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseCreateSolutionDialog" />
                </MudStack>

                @if (!string.IsNullOrWhiteSpace(_createSolutionMessage))
                {
                    <MudAlert Severity="@_createSolutionMessageSeverity" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                        @_createSolutionMessage
                    </MudAlert>
                }

                <MudForm @ref="_createSolutionForm">
                    <MudGrid>
                        <MudItem xs="12" md="6"><MudTextField T="string" Label="Code" @bind-Value="_solutionRequest.Code" Required="true" RequiredError="Code is required." /></MudItem>
                        <MudItem xs="12" md="6"><MudTextField T="string" Label="Name" @bind-Value="_solutionRequest.Name" Required="true" RequiredError="Name is required." /></MudItem>
                        <MudItem xs="12"><MudTextField T="string" Label="Description" @bind-Value="_solutionRequest.Description" Lines="3" /></MudItem>
                        <MudItem xs="12"><MudTextField T="string" Label="Repository Path" @bind-Value="_solutionRequest.RepositoryPath" Required="true" RequiredError="Repository path is required." /></MudItem>
                        <MudItem xs="12" md="6"><MudTextField T="string" Label="Main Solution File" @bind-Value="_solutionRequest.MainSolutionFile" Required="true" RequiredError="Main solution file is required." /></MudItem>
                        <MudItem xs="12" md="3"><MudTextField T="string" Label="Profile Code" @bind-Value="_solutionRequest.ProfileCode" Required="true" RequiredError="Profile code is required." /></MudItem>
                        <MudItem xs="12" md="3"><MudTextField T="string" Label="Overlay Code" @bind-Value="_solutionRequest.SolutionOverlayCode" Required="true" RequiredError="Solution overlay code is required." /></MudItem>
                        <MudItem xs="12"><MudTextField T="string" Label="Remote Repository URL" @bind-Value="_solutionRequest.RemoteRepositoryUrl" /></MudItem>
                    </MudGrid>
                </MudForm>

                <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1" Class="mt-4">
                    <MudButton Variant="Variant.Text" OnClick="CloseCreateSolutionDialog">Cancel</MudButton>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Disabled="_savingSolution" OnClick="CreateSolutionAsync">Create solution</MudButton>
                </MudStack>
            </MudPaper>
        </div>
    </MudOverlay>
}

@code {
    private static readonly IReadOnlyList<LaneDefinition> _lanes =
    [
        new(LaneKeys.Requirement, "Requirement", "Intake"),
    new(LaneKeys.Analysis, "Analysis", "analyze-request"),
    new(LaneKeys.Design, "Design", "design-solution-change"),
    new(LaneKeys.Planning, "Planning", "plan-implementation"),
    new(LaneKeys.Implementation, "Implementation", "implement-solution-change"),
    new(LaneKeys.Test, "Test", "validation"),
    new(LaneKeys.Review, "Review", "review"),
    new(LaneKeys.Deliver, "Deliver", "delivery"),
    new(LaneKeys.Documentation, "Documentation", "docs")
    ];

    private readonly List<SolutionSummary> _solutions = [];
    private readonly List<RequirementRow> _requirements = [];
    private readonly List<BacklogRow> _backlog = [];
    private readonly List<WorkflowRunRow> _runs = [];
    private readonly List<SolutionDocumentSummary> _documents = [];
    private MudForm? _createSolutionForm;
    private Guid? _selectedSolutionId;
    private bool _loading;
    private bool _drawerOpen;
    private bool _documentsLoading;
    private bool _createSolutionDialogOpen;
    private bool _savingSolution;
    private Guid? _runningRequirementId;
    private Guid? _runningBacklogItemId;
    private string? _loadError;
    private string? _createSolutionMessage;
    private Severity _createSolutionMessageSeverity = Severity.Info;
    private RequirementStageCard? _activeCard;
    private SolutionDocumentContent? _activeDocument;
    private readonly SetupSolutionModel _solutionRequest = new();

    protected override async Task OnInitializedAsync()
    {
        SelectedSolutionState.Changed += HandleSolutionChanged;
        await LoadSolutionsAsync();
        await EnsureSelectedSolutionAsync();
        await LoadCockpitAsync();
    }

    private async void HandleSolutionChanged()
    {
        _selectedSolutionId = SelectedSolutionState.Current?.SolutionId;
        await InvokeAsync(async () =>
        {
            await LoadDocumentsAsync();
            await LoadCockpitAsync();
        });
    }

    private async Task LoadSolutionsAsync()
    {
        var client = HttpClientFactory.CreateClient("api");
        _solutions.Clear();
        _solutions.AddRange(await client.GetFromJsonAsync<List<SolutionSummary>>("api/solutions") ?? []);
    }

    private async Task EnsureSelectedSolutionAsync()
    {
        if (SelectedSolutionState.Current is not null)
        {
            _selectedSolutionId = SelectedSolutionState.Current.SolutionId;
            return;
        }

        var first = _solutions.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase).FirstOrDefault();
        if (first is not null)
        {
            _selectedSolutionId = first.SolutionId;
            SelectedSolutionState.SetCurrent(first);
            await LoadDocumentsAsync();
        }
    }

    private async Task OnSolutionSelectionChangedAsync(Guid? solutionId)
    {
        _selectedSolutionId = solutionId;
        var selected = _solutions.FirstOrDefault(x => x.SolutionId == solutionId);
        SelectedSolutionState.SetCurrent(selected);
        await LoadDocumentsAsync();
        await LoadCockpitAsync();
    }

    private async Task LoadCockpitAsync()
    {
        _requirements.Clear();
        _backlog.Clear();
        _runs.Clear();
        _loadError = null;

        if (SelectedSolutionState.Current is null)
        {
            StateHasChanged();
            return;
        }

        _loading = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var solutionId = SelectedSolutionState.Current.SolutionId;
            _requirements.AddRange(await client.GetFromJsonAsync<List<RequirementRow>>($"api/solutions/{solutionId}/requirements") ?? []);
            _backlog.AddRange(await client.GetFromJsonAsync<List<BacklogRow>>($"api/backlog-items?solutionId={solutionId}") ?? []);
            _runs.AddRange(await client.GetFromJsonAsync<List<WorkflowRunRow>>($"api/workflow-runs?solutionId={solutionId}") ?? []);
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDocumentsAsync()
    {
        _documents.Clear();

        if (SelectedSolutionState.Current is null)
        {
            return;
        }

        _documentsLoading = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            _documents.AddRange(await client.GetFromJsonAsync<List<SolutionDocumentSummary>>($"api/solutions/{SelectedSolutionState.Current.SolutionId}/documents") ?? []);
        }
        finally
        {
            _documentsLoading = false;
            StateHasChanged();
        }
    }

    private Dictionary<string, RequirementStageCard> BuildRow(RequirementRow requirement)
    {
        var row = new Dictionary<string, RequirementStageCard>(StringComparer.OrdinalIgnoreCase)
            {
                [LaneKeys.Requirement] = new RequirementStageCard(
                    LaneKeys.Requirement,
                    "Requirement",
                    requirement.Title,
                    requirement.Description,
                    requirement.CreatedAtUtc.ToLocalTime().ToString("dd MMM"),
                    HumanizeRequirementStatus(requirement.Status),
                    GetStatusColor(requirement.Status),
                    requirement,
                    null,
                    GetLatestRun(requirement.Id, null))
            };

        var requirementRunGroups = _runs
            .Where(x => x.RequirementId == requirement.Id)
            .GroupBy(x => x.WorkflowCode, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.OrderByDescending(x => x.StartedUtc).First(), StringComparer.OrdinalIgnoreCase);

        AddRequirementWorkflowCard(row, LaneKeys.Analysis, requirementRunGroups, requirement, "analyze-request", "Analysis");
        AddRequirementWorkflowCard(row, LaneKeys.Design, requirementRunGroups, requirement, "design-solution-change", "Design");
        AddRequirementWorkflowCard(row, LaneKeys.Planning, requirementRunGroups, requirement, "plan-implementation", "Planning");

        var backlogItem = _backlog
            .Where(x => x.RequirementId == requirement.Id)
            .OrderBy(x => x.PlanningOrder)
            .ThenBy(x => x.CreatedUtc)
            .FirstOrDefault(x => !string.Equals(x.Status, "Validated", StringComparison.OrdinalIgnoreCase) && !string.Equals(x.Status, "Canceled", StringComparison.OrdinalIgnoreCase))
            ?? _backlog.Where(x => x.RequirementId == requirement.Id).OrderByDescending(x => x.PlanningOrder).FirstOrDefault();

        if (backlogItem is not null)
        {
            var implementationRun = GetLatestRun(requirement.Id, backlogItem.Id);
            row[LaneKeys.Implementation] = new RequirementStageCard(
                LaneKeys.Implementation,
                "Implementation",
                backlogItem.Title,
                backlogItem.Description,
                backlogItem.CreatedUtc.ToLocalTime().ToString("dd MMM"),
                HumanizeBacklogStatus(backlogItem.Status),
                GetStatusColor(backlogItem.Status),
                requirement,
                backlogItem,
                implementationRun);

            if (string.Equals(backlogItem.Status, "AwaitingValidation", StringComparison.OrdinalIgnoreCase))
            {
                row[LaneKeys.Test] = new RequirementStageCard(
                    LaneKeys.Test,
                    "Test",
                    backlogItem.Title,
                    "Implementation is waiting for validation before the next slice can continue.",
                    (backlogItem.UpdatedUtc ?? backlogItem.CreatedUtc).ToLocalTime().ToString("dd MMM"),
                    "Awaiting validation",
                    GetStatusColor("awaiting-validation"),
                    requirement,
                    backlogItem,
                    implementationRun);
            }
        }

        if (HasDocumentation(requirement))
        {
            row[LaneKeys.Documentation] = new RequirementStageCard(
                LaneKeys.Documentation,
                "Documentation",
                "SDLC documents",
                "Solution SDLC documentation workspace is available for this requirement context.",
                requirement.CreatedAtUtc.ToLocalTime().ToString("dd MMM"),
                _documents.Count == 0 ? "Empty" : "Available",
                _documents.Count == 0 ? "#94a3b8" : "#0f766e",
                requirement,
                null,
                null);
        }

        return row;
    }

    private void AddRequirementWorkflowCard(
        IDictionary<string, RequirementStageCard> row,
        string laneKey,
        IReadOnlyDictionary<string, WorkflowRunRow> runs,
        RequirementRow requirement,
        string workflowCode,
        string laneTitle)
    {
        if (!runs.TryGetValue(workflowCode, out var run))
        {
            return;
        }

        row[laneKey] = new RequirementStageCard(
            laneKey,
            laneTitle,
            requirement.Title,
            requirement.Description,
            run.StartedUtc.ToLocalTime().ToString("dd MMM"),
            HumanizeWorkflowStatus(run.Status),
            GetStatusColor(run.Status.ToString()),
            requirement,
            null,
            run);
    }

    private WorkflowRunRow? GetLatestRun(Guid requirementId, Guid? backlogItemId)
        => _runs
            .Where(x => x.RequirementId == requirementId && x.BacklogItemId == backlogItemId)
            .OrderByDescending(x => x.StartedUtc)
            .FirstOrDefault();

    private bool HasDocumentation(RequirementRow requirement)
        => _documents.Count > 0 && !string.IsNullOrWhiteSpace(requirement.Status);

    private void OpenCard(RequirementStageCard card)
    {
        _activeDocument = null;
        _activeCard = card;
        _drawerOpen = true;
    }

    private async Task OpenDocumentAsync(SolutionDocumentSummary document)
    {
        if (SelectedSolutionState.Current is null)
        {
            return;
        }

        var client = HttpClientFactory.CreateClient("api");
        var path = Uri.EscapeDataString(document.RelativePath);
        _activeDocument = await client.GetFromJsonAsync<SolutionDocumentContent>($"api/solutions/{SelectedSolutionState.Current.SolutionId}/documents/content?path={path}");
        _activeCard = null;
        _drawerOpen = true;
    }

