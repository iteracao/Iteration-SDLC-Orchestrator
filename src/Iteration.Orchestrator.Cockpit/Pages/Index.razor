@page "/"

<PageTitle>Cockpit</PageTitle>

<div class="cockpit-shell">
    <CockpitToolbar SelectedTargetId="_selectedTargetId"
                    SolutionTargetOptions="_solutionTargetOptions"
                    SelectedTargetChanged="OnSolutionSelectionChangedAsync"
                    CurrentSolution="SelectedSolutionState.Current"
                    IsTargetSelectionLocked="IsTargetSelectionLocked"
                    CanOpenSolutionPanel="CanOpenSolutionPanel"
                    OpenCreateSolution="OpenCreateSolutionPanel"
                    DocumentsLoading="_documentsLoading"
                    Documents="_documents"
                    OpenDocument="OpenDocumentAsync"
                    CanOpenDocumentationWorkflowModal="CanOpenDocumentationWorkflowModal"
                    OpenDocumentationWorkflow="OpenDocumentationWorkflowModalAsync"
                    CanOpenRequirementPanel="CanOpenRequirementPanel"
                    OpenCreateRequirement="OpenCreateRequirementPanel" />

    @if (_createSolutionPanelOpen)
    {
        <CreateSolutionPanel Model="_solutionRequest"
                             OverlayOptions="OverlayOptions"
                             OverlayTargetChanged="OnOverlayTargetChangedAsync"
                             Saving="_savingSolution"
                             Message="_createSolutionMessage"
                             MessageSeverity="_createSolutionMessageSeverity"
                             Cancel="CloseCreateSolutionPanel"
                             Submit="CreateSolutionAsync" />
    }

    @if (_createRequirementPanelOpen)
    {
        <CreateRequirementPanel Model="_requirementRequest"
                                SelectedTargetLabel="SelectedTargetLabel"
                                Saving="_savingRequirement"
                                Message="_createRequirementMessage"
                                MessageSeverity="_createRequirementMessageSeverity"
                                Cancel="CloseCreateRequirementPanel"
                                Submit="CreateRequirementAsync" />
    }

    @if (_loading)
    {
        <MudPaper Class="pa-8" Elevation="0">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Typo="Typo.body2">Loading cockpit...</MudText>
            </MudStack>
        </MudPaper>
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
            @_loadError
        </MudAlert>
    }
    else if (SelectedSolutionState.Current is null)
    {
        <MudPaper Class="cockpit-empty-state" Elevation="0">
            <MudText Typo="Typo.body2" Class="cockpit-empty-state-text">
                Select a solution or create a new one to start using the cockpit.
            </MudText>
        </MudPaper>
    }
    else
    {
        <RequirementsBoard Pipelines="RequirementPipelines"
                           BuildPipelineTooltip="BuildPipelineTooltip"
                           GetConnectorColor="GetConnectorColor"
                           OpenCard="OpenCardAsync" />
    }
</div>

<RequirementDrawer IsOpen="_drawerOpen"
                   ActiveDocument="_activeDocument"
                   ActiveCard="_activeCard"
                   ActiveWorkflowRunDetails="_activeWorkflowRunDetails"
                   ActiveWorkflowRunDetailsLoading="_activeWorkflowRunDetailsLoading"
                   RequirementStatusText="@(_activeCard is null ? string.Empty : HumanizeRequirementStatus(_activeCard.Requirement.Status))"
                   RequirementPriority="@(_activeCard?.Requirement.Priority ?? string.Empty)"
                   WorkflowRunStatusText="@(_activeCard?.WorkflowRun is null ? string.Empty : HumanizeWorkflowStatus(_activeCard.WorkflowRun.Status))"
                   CanViewOutputPayload="@CanViewWorkflowOutput(_activeWorkflowRunDetails)"
                   RecordedDocumentationUpdates="ActiveRecordedDocumentationUpdates"
                   RecordedKnowledgeUpdates="ActiveRecordedKnowledgeUpdates"
                   ShowRunButton="ActiveCardCanRun"
                   RunBusy="ActiveCardRunBusy"
                   Run="@(async () => { if (_activeCard is not null) await RunAsync(_activeCard); })"
                   ShowValidateButton="ActiveCardCanValidate"
                   ValidateBusy="@(_activeCard?.WorkflowRun is not null && _mutatingWorkflowRunId == _activeCard.WorkflowRun.Id)"
                   Validate="@(async () => { if (_activeCard?.WorkflowRun is not null) await ValidateWorkflowRunAsync(_activeCard.WorkflowRun.Id); })"
                   ShowCancelWorkflowButton="ActiveCardCanCancelWorkflow"
                   CancelWorkflowBusy="@(_activeCard?.WorkflowRun is not null && _mutatingWorkflowRunId == _activeCard.WorkflowRun.Id)"
                   CancelWorkflow="@(async () => { if (_activeCard?.WorkflowRun is not null) await CancelWorkflowRunAsync(_activeCard.WorkflowRun.Id); })"
                   ShowViewLogButton="ActiveCardCanViewLog"
                   ViewLog="@(async () => { if (_activeCard?.WorkflowRun is not null) await OpenWorkflowLogAsync(_activeCard.WorkflowRun.Id); })"
                   ShowViewReportButton="ActiveCardCanViewReport"
                   ViewReportDisabled="@(!CanViewWorkflowReport(_activeWorkflowRunDetails))"
                   ViewReport="@(async () => { if (_activeCard?.WorkflowRun is not null) await OpenWorkflowReportAsync(_activeCard.WorkflowRun.Id); })"
                   ShowDeleteRequirementButton="ActiveCardCanDeleteRequirement"
                   RequirementMutationBusy="@(_activeCard is not null && _mutatingRequirementId == _activeCard.Requirement.Id)"
                   DeleteRequirement="@(async () => { if (_activeCard is not null) await DeleteRequirementAsync(_activeCard.Requirement.Id); })"
                   ShowCancelRequirementButton="ActiveCardCanCancelRequirement"
                   CancelRequirement="@(async () => { if (_activeCard is not null) await CancelRequirementAsync(_activeCard.Requirement.Id); })"
                   ShowRequirementDecisionActions="ActiveCardShowRequirementDecisionActions"
                   CommitRequirement="@(async () => { if (_activeCard is not null) await CommitRequirementAsync(_activeCard.Requirement.Id); })"
                   OpenArtifact="@(async file => { if (_activeCard?.WorkflowRun is not null) await OpenWorkflowArtifactAsync(_activeCard.WorkflowRun.Id, file); })"
                   Close="CloseDrawer" />

<DocumentationWorkflowDialog IsOpen="_documentationWorkflowModalOpen"
                             LatestRun="CurrentDocumentationWorkflowRun"
                             LatestRunStatusText="@(CurrentDocumentationWorkflowRun is null ? string.Empty : HumanizeWorkflowStatus(CurrentDocumentationWorkflowRun.Status))"
                             SelectedTargetLabel="@SelectedTargetLabel"
                             Message="@_documentationWorkflowMessage"
                             MessageSeverity="@_documentationWorkflowMessageSeverity"
                             Log="@_documentationWorkflowLog"
                             LogLoading="@_documentationWorkflowLogLoading"
                             CopyLogDisabled="@(!CanCopyDocumentationWorkflowLog)"
                             CopyLog="CopyDocumentationWorkflowLogToClipboardAsync"
                             RunDisabled="@(DocumentationWorkflowRunDisabled || SelectedSolutionState.CurrentTarget is null)"
                             RunWorkflow="RunDocumentationWorkflowAsync"
                             Close="CloseDocumentationWorkflowModal" />

<WorkflowViewerDialog IsOpen="_viewerOpen"
                      ActiveWorkflowArtifact="_activeWorkflowArtifact"
                      ActiveWorkflowLog="_activeWorkflowLog"
                      Title="ViewerTitle"
                      Subtitle="ViewerSubtitle"
                      Copy="CopyViewerContentToClipboardAsync"
                      Close="CloseViewer"
                      OpenArtifact="@(async file => { if (_activeWorkflowLog is not null) await OpenWorkflowArtifactAsync(_activeWorkflowLog.WorkflowRunId, file); })" />
