@page "/"
@using System.Net.Http.Json
@using Iteration.Orchestrator.Cockpit.Models
@inject IHttpClientFactory HttpClientFactory
@inject Iteration.Orchestrator.Cockpit.Services.SelectedSolutionState SelectedSolutionState
@implements IDisposable

<PageTitle>Cockpit</PageTitle>

<style>
    .cockpit-shell {
        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .cockpit-toolbar {
        background: #f5f7fa;
        border: 1px solid #d9e0e8;
        border-radius: 12px;
        padding: 4px 8px;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
    }

    .cockpit-toolbar-row {
        gap: 5px;
    }

    .toolbar-select-host,
    .create-panel .mud-select {
        flex: 1;
        min-width: 0;
    }

    .toolbar-select-host .mud-input-control,
    .create-panel .mud-select .mud-input-control {
        margin-top: 0;
    }

    .toolbar-select-host .mud-input-control-input-container,
    .create-panel .mud-select .mud-input-control-input-container {
        background: #ffffff;
        border-radius: 9px;
    }

    .toolbar-select-host .mud-input-label,
    .create-panel .mud-select .mud-input-label {
        font-size: 0.66rem;
        color: #64748b;
        background: #ffffff;
        padding: 0 3px;
    }

    .toolbar-select-host .mud-input > input,
    .toolbar-select-host .mud-select-input,
    .create-panel .mud-select .mud-input > input,
    .create-panel .mud-select .mud-select-input {
        font-size: 0.86rem;
        color: #1e293b;
        font-family: inherit;
        font-weight: 400;
    }

    .toolbar-select-host .mud-input-label.mud-input-label-inputcontrol,
    .create-panel .mud-select .mud-input-label.mud-input-label-inputcontrol {
        font-size: 0.66rem;
    }

    .toolbar-select-host .mud-input-slot,
    .create-panel .mud-select .mud-input-slot {
        display: flex;
        align-items: center;
        min-height: 32px;
        height: 32px;
        background: #ffffff;
        padding-top: 0;
        padding-bottom: 0;
        padding-left: 10px;
        padding-right: 10px;
    }

    .toolbar-select-host .mud-input-root,
    .create-panel .mud-select .mud-input-root {
        font-size: 0.86rem;
    }

    .toolbar-select-host .mud-input-outlined,
    .create-panel .mud-select .mud-input-outlined {
        --mud-palette-lines-inputs: #cbd5e1;
    }

    .toolbar-select-host .mud-input-outlined-border,
    .create-panel .mud-select .mud-input-outlined-border {
        border-color: #cbd5e1 !important;
        border-width: 1px !important;
    }

    .toolbar-select-host .mud-input-root:hover .mud-input-outlined-border,
    .create-panel .mud-select .mud-input-root:hover .mud-input-outlined-border {
        border-color: #b8c4d4 !important;
    }

    .toolbar-select-host .mud-input-root.mud-input-focused .mud-input-outlined-border,
    .create-panel .mud-select .mud-input-root.mud-input-focused .mud-input-outlined-border {
        border-color: #b8c4d4 !important;
    }

    .toolbar-select-host .mud-input-root.mud-input-focused .mud-input-label,
    .create-panel .mud-select .mud-input-root.mud-input-focused .mud-input-label {
        color: #64748b;
    }

    .toolbar-select-host .mud-select-input,
    .toolbar-select-host .mud-input-label-inputcontrol,
    .create-panel .mud-select .mud-select-input,
    .create-panel .mud-select .mud-input-label-inputcontrol {
        line-height: 1.2;
        display: flex;
        align-items: center;
    }

    .toolbar-select-host .mud-input-adornment,
    .create-panel .mud-select .mud-input-adornment {
        margin-top: 0;
        align-self: center;
        height: 100%;
        display: flex;
        align-items: center;
    }

    .toolbar-select-host .mud-input-adornment-end,
    .create-panel .mud-select .mud-input-adornment-end {
        margin-inline-start: auto;
        padding-left: 0;
        flex: 0 0 auto;
    }

    .toolbar-select-host .mud-icon-root,
    .create-panel .mud-select .mud-icon-root {
        color: #64748b;
        font-size: 0.92rem;
    }

    .toolbar-select-host .mud-select-input,
    .create-panel .mud-select .mud-select-input {
        padding-top: 0;
        padding-bottom: 0;
        min-height: 100%;
        height: 100%;
        flex: 1 1 auto;
        align-self: stretch;
        padding-right: 0;
        box-sizing: border-box;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        transform: translateY(1px);
    }

    .toolbar-action-button {
        width: 31px;
        height: 31px;
        border: 1px solid #cfd8e3;
        border-radius: 999px;
        background: #ffffff;
        color: #5b6878;
        transition: background-color 0.14s ease, border-color 0.14s ease, box-shadow 0.14s ease, color 0.14s ease;
    }

    .toolbar-action-button:hover {
        background: #f8fafc;
        border-color: #bcc7d5;
        color: #1e293b;
    }

    .toolbar-action-button:focus-visible {
        outline: none;
        box-shadow: 0 0 0 3px rgba(91, 79, 229, 0.12);
    }

    .toolbar-action-button.toolbar-action-primary {
        background: #eef2f8;
        border-color: #cfd8e3;
        color: #4b5b70;
    }

    .toolbar-action-button.toolbar-action-primary .mud-icon-root {
        color: #4b5b70;
    }

    .toolbar-action-button .mud-icon-root {
        font-size: 0.92rem;
    }

    .toolbar-action-button.toolbar-action-primary:hover {
        background: #e6ebf3;
        border-color: #bcc7d5;
        color: #334155;
    }

    .toolbar-action-button.toolbar-action-disabled {
        background: #f2f5f9;
        border-color: #e5e7eb;
        color: #94a3b8;
    }

    .create-panel {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 10px 12px;
    }

    .create-panel-header {
        margin-bottom: 8px;
    }

    .create-panel-title {
        font-size: 0.98rem;
        font-weight: 700;
        color: #1e293b;
        line-height: 1.2;
    }

    .create-panel-close {
        width: 28px;
        height: 28px;
        color: #64748b;
    }

    .create-panel-form-grid {
        --mud-grid-spacing-xs: 8px;
        --mud-grid-spacing-sm: 8px;
        --mud-grid-spacing-md: 8px;
    }

    .create-panel .mud-alert {
        padding-top: 6px;
        padding-bottom: 6px;
        font-size: 0.8rem;
    }

    .create-panel .mud-input-control {
        margin-top: 0;
    }

    .create-panel .mud-input-label {
        font-size: 0.64rem;
        color: #64748b;
    }

    .create-panel .mud-input > input,
    .create-panel .mud-select-input,
    .create-panel .mud-input > textarea {
        font-size: 0.84rem;
        color: #1e293b;
        font-family: inherit;
        font-weight: 400;
    }

    .create-panel .mud-input-label.mud-input-label-inputcontrol {
        font-size: 0.64rem;
    }

    .create-panel .mud-input-slot {
        display: flex;
        align-items: center;
        position: relative;
        min-height: 32px;
        background: #ffffff;
        padding-top: 0;
        padding-bottom: 0;
        padding-left: 10px;
        padding-right: 10px;
    }

    .create-panel .mud-input-outlined-border {
        border-width: 1px !important;
    }

    .create-panel .mud-input-adornment {
        margin-top: 0;
        align-self: center;
        height: 100%;
        display: flex;
        align-items: center;
    }

    .create-panel .mud-input-adornment .mud-icon-root,
    .create-panel .mud-input-slot .mud-icon-root {
        font-size: 0.9rem;
        color: #64748b;
    }

    .create-panel .mud-input-control-helper-container .mud-input-helper-text,
    .create-panel .mud-input-control-helper-container .mud-input-error {
        color: transparent !important;
        font-size: 0 !important;
        line-height: 0 !important;
        user-select: none;
    }

    .create-panel .mud-input > textarea {
        min-height: 68px;
    }

    .create-panel .mud-select-input,
    .create-panel .mud-input > input {
        min-height: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        line-height: 1.2;
        padding-top: 0;
        padding-bottom: 0;
        box-sizing: border-box;
    }

    .create-panel .mud-input-label-inputcontrol {
        line-height: 1;
    }

    .toolbar-select-host .mud-select-icon,
    .create-panel .mud-select-icon,
    .toolbar-select-host .mud-input-adornment-end,
    .create-panel .mud-input-adornment-end {
        display: none !important;
    }

    .create-panel-actions {
        margin-top: 10px;
        gap: 6px;
    }

    .create-panel-actions .mud-button-root {
        min-width: 0;
        height: 30px;
        padding: 0 10px;
        font-size: 0.8rem;
    }

    .cockpit-board {
        background: #ffffff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        padding: 10px 12px;
    }

    .pipeline-card-list {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .requirement-pipeline-card {
        background: linear-gradient(180deg, #ffffff 0%, #fbfdff 100%);
        border: 1px solid var(--pipeline-color, #cbd5e1);
        border-left-width: 4px;
        border-radius: 14px;
        padding: 14px 16px;
        box-shadow: 0 10px 28px rgba(15, 23, 42, 0.04);
    }

    .pipeline-card-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 14px;
    }

    .pipeline-card-meta {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: wrap;
    }

    .pipeline-requirement-chip {
        max-width: 100%;
        border-color: var(--pipeline-color, #cbd5e1) !important;
        color: #1e293b !important;
        background: #ffffff !important;
        font-weight: 700;
    }

    .pipeline-status-chip {
        border-color: var(--pipeline-color, #cbd5e1) !important;
        color: var(--pipeline-color, #64748b) !important;
        background: transparent !important;
        font-weight: 600;
    }

    .pipeline-card-date {
        font-size: 0.75rem;
        color: #64748b;
        white-space: nowrap;
    }

    .pipeline-card-description {
        margin: 0 0 14px 0;
        font-size: 0.86rem;
        line-height: 1.45;
        color: #475569;
    }

    .pipeline-flow {
        display: flex;
        align-items: center;
        gap: 0;
        overflow-x: auto;
        padding-bottom: 4px;
    }

    .pipeline-step-shell {
        display: flex;
        align-items: center;
        flex: 1 1 0;
        min-width: 68px;
    }

    .pipeline-step-shell:last-child {
        flex: 0 0 auto;
    }

    .pipeline-step {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 6px;
        flex: 0 0 auto;
    }

    .pipeline-step-button {
        width: 42px;
        height: 42px;
        border: 2px solid var(--step-color, #cbd5e1);
        border-radius: 999px;
        background: #ffffff;
        color: var(--step-color, #64748b);
        transition: transform 0.14s ease, box-shadow 0.14s ease, border-color 0.14s ease, background-color 0.14s ease, color 0.14s ease;
    }

    .pipeline-step-button:hover:not(:disabled) {
        transform: translateY(-1px);
        box-shadow: 0 8px 20px rgba(15, 23, 42, 0.10);
    }

    .pipeline-step-button:focus-visible {
        outline: none;
        box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.18);
    }

    .pipeline-step-button:disabled {
        background: #f8fafc;
        color: var(--step-color, #94a3b8);
        opacity: 1;
    }

    .pipeline-step-button.is-running {
        box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.12);
    }

    .pipeline-step-button.is-waiting {
        background: #fffdf4;
    }

    .pipeline-step-button.is-complete {
        background: #f3fbf7;
    }

    .pipeline-step-button.is-error {
        background: #fff5f5;
    }

    .pipeline-step-dot {
        width: 6px;
        height: 6px;
        border-radius: 999px;
        background: var(--step-color, #cbd5e1);
    }

    .pipeline-step-connector {
        height: 2px;
        flex: 1 1 auto;
        min-width: 28px;
        margin: 0 10px;
        background: linear-gradient(90deg, var(--line-color, #dbe4ee) 0%, var(--line-color, #dbe4ee) 100%);
    }

    .board-empty {
        min-height: 84px;
        padding: 10px 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: #64748b;
    }

    .drawer-section {
        display: flex;
        flex-direction: column;
        gap: 14px;
    }

    .drawer-content-block {
        border: 1px solid #e5e7eb;
        border-radius: 12px;
        padding: 14px;
        background: #ffffff;
    }

    .doc-pre {
        white-space: pre-wrap;
        word-break: break-word;
        margin: 0;
        font-family: Consolas, 'Courier New', monospace;
        font-size: 0.82rem;
        color: #334155;
    }
</style>

<div class="cockpit-shell">
    <MudPaper Class="cockpit-toolbar" Elevation="0">
        <MudStack Row="true" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Class="cockpit-toolbar-row">
            <div class="toolbar-select-host">
                <MudSelect T="Guid?"
                           Value="_selectedSolutionId"
                           ValueChanged="OnSolutionSelectionChangedAsync"
                           Label="Solution"
                           Variant="Variant.Outlined"
                           Margin="Margin.Dense"
                           Dense="true"
                           FullWidth="true">
                    @foreach (var solution in _solutions)
                    {
                        <MudSelectItem T="Guid?" Value="@solution.SolutionId">@solution.Name</MudSelectItem>
                    }
                </MudSelect>
            </div>

            <MudIconButton Icon="@Icons.Material.Filled.Add"
                           Size="Size.Small"
                           Class="toolbar-action-button toolbar-action-primary"
                           OnClick="OpenCreateSolutionPanel"
                           aria-label="Create Solution" />

            <MudMenu Dense="true"
                     Disabled="SelectedSolutionState.Current is null || _documentsLoading">
                <ActivatorContent>
                    <MudTooltip Text="Documentation">
                        <MudIconButton Icon="@Icons.Material.Filled.Description"
                                       Size="Size.Small"
                                       Class="@($"toolbar-action-button{(SelectedSolutionState.Current is null || _documentsLoading ? " toolbar-action-disabled" : string.Empty)}")"
                                       Disabled="SelectedSolutionState.Current is null || _documentsLoading"
                                       aria-label="Documentation" />
                    </MudTooltip>
                </ActivatorContent>
                <ChildContent>
                    @if (_documentsLoading)
                    {
                        <MudMenuItem Disabled="true">Loading documents...</MudMenuItem>
                    }
                    else if (_documents.Count == 0)
                    {
                        <MudMenuItem Disabled="true">No SDLC documents found</MudMenuItem>
                    }
                    else
                    {
                        @foreach (var document in _documents)
                        {
                            <MudMenuItem OnClick="() => OpenDocumentAsync(document)">@document.Name</MudMenuItem>
                        }
                    }
                </ChildContent>
            </MudMenu>
        </MudStack>
    </MudPaper>

    @if (_createSolutionPanelOpen)
    {
        <MudPaper Class="create-panel" Elevation="0">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="create-panel-header">
                <MudText Class="create-panel-title">Create / setup solution</MudText>
                <MudIconButton Icon="@Icons.Material.Filled.Close"
                               Size="Size.Small"
                               Class="create-panel-close"
                               OnClick="CloseCreateSolutionPanel" />
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(_createSolutionMessage))
            {
                <MudAlert Severity="@_createSolutionMessageSeverity" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                    @_createSolutionMessage
                </MudAlert>
            }

            <MudForm @ref="_createSolutionForm">
                <MudGrid Class="create-panel-form-grid" Spacing="1">
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Solution name" @bind-Value="_solutionRequest.Name" Required="true" RequiredError="Name is required." Margin="Margin.Dense" Dense="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Profile" Value="@_solutionRequest.ProfileCode" ReadOnly="true" Disabled="true" Margin="Margin.Dense" Dense="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Description" @bind-Value="_solutionRequest.Description" Lines="3" Margin="Margin.Dense" Dense="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="Repository folder" @bind-Value="_solutionRequest.RepositoryPath" Required="true" RequiredError="Repository path is required." Margin="Margin.Dense" Dense="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="6">
                        <MudTextField T="string" Label="Main solution file" @bind-Value="_solutionRequest.MainSolutionFile" Required="true" RequiredError="Main solution file is required." Margin="Margin.Dense" Dense="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudTextField T="string" Label="Target" Value="@_solutionRequest.TargetCode" ReadOnly="true" Disabled="true" Margin="Margin.Dense" Dense="true" Variant="Variant.Outlined" />
                    </MudItem>
                    <MudItem xs="12" md="3">
                        <MudSelect T="Guid?" Label="Overlay source" Value="_solutionRequest.OverlayTargetId" ValueChanged="OnOverlayTargetChangedAsync" Margin="Margin.Dense" Dense="true" Variant="Variant.Outlined">
                            <MudSelectItem T="Guid?" Value="@((Guid?)null)">(none)</MudSelectItem>
                            @foreach (var overlayOption in OverlayOptions)
                            {
                                <MudSelectItem T="Guid?" Value="@overlayOption.Target.Id">@overlayOption.Label</MudSelectItem>
                            }
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12">
                        <MudTextField T="string" Label="GitHub repository URL" HelperText="Required. Must exist on GitHub. If the repository is private, configure GITHUB_TOKEN in environment variables." @bind-Value="_solutionRequest.RemoteRepositoryUrl" Required="true" RequiredError="GitHub repository URL is required." Margin="Margin.Dense" Dense="true" Variant="Variant.Outlined" />
                    </MudItem>
                </MudGrid>
            </MudForm>

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="1" Class="create-panel-actions">
                <MudButton Variant="Variant.Text" Size="Size.Small" OnClick="CloseCreateSolutionPanel">Cancel</MudButton>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small" Disabled="_savingSolution" OnClick="CreateSolutionAsync">
                    Create solution
                </MudButton>
            </MudStack>
        </MudPaper>
    }

    @if (_loading)
    {
        <MudPaper Class="pa-8" Elevation="0">
            <MudStack AlignItems="AlignItems.Center" Spacing="2">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                <MudText Typo="Typo.body2">Loading cockpit...</MudText>
            </MudStack>
        </MudPaper>
    }
    else if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true">
            @_loadError
        </MudAlert>
    }
    else if (SelectedSolutionState.Current is null)
    {
        <MudPaper Class="pa-4" Elevation="0" Style="border:1px dashed #cbd5e1; border-radius:12px; background:#ffffff;">
            <MudText Typo="Typo.body2" Style="color:#64748b;">
                Select a solution or create a new one to start using the cockpit.
            </MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="cockpit-board" Elevation="0">
            @if (_requirements.Count == 0)
            {
                <div class="board-empty">
                    No requirements exist yet for the selected solution.
                </div>
            }
            else
            {
                <div class="pipeline-card-list">
                    @foreach (var requirement in _requirements)
                    {
                        var pipeline = BuildPipeline(requirement);

                        <div class="requirement-pipeline-card" style="@($"--pipeline-color:{pipeline.RequirementState.Color};")">
                            <div class="pipeline-card-header">
                                <div class="pipeline-card-meta">
                                    <MudChip T="string"
                                             Class="pipeline-requirement-chip"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @pipeline.Requirement.Title
                                    </MudChip>
                                    <MudChip T="string"
                                             Class="pipeline-status-chip"
                                             Variant="Variant.Outlined"
                                             Size="Size.Small">
                                        @pipeline.RequirementState.Label
                                    </MudChip>
                                </div>
                                <div class="pipeline-card-date">
                                    Created @pipeline.Requirement.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd")
                                </div>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(pipeline.Requirement.Description))
                            {
                                <p class="pipeline-card-description">@pipeline.Requirement.Description</p>
                            }

                            <div class="pipeline-flow">
                                @for (var index = 0; index < pipeline.Steps.Count; index++)
                                {
                                    var step = pipeline.Steps[index];

                                    <div class="pipeline-step-shell">
                                        <div class="pipeline-step">
                                            <MudTooltip Text="@BuildPipelineTooltip(step)">
                                                <MudIconButton Icon="@step.Icon"
                                                               Size="Size.Medium"
                                                               Disabled="@step.Disabled"
                                                               Class="@($"pipeline-step-button {step.State.CssClass}")"
                                                               Style="@($"--step-color:{step.State.Color};")"
                                                               aria-label="@step.LaneTitle"
                                                               @onclick="() => OpenCard(step.Card)" />
                                            </MudTooltip>
                                            <span class="pipeline-step-dot" style="@($"--step-color:{step.State.Color};")"></span>
                                        </div>

                                        @if (index < pipeline.Steps.Count - 1)
                                        {
                                            var connectorColor = GetConnectorColor(step.State, pipeline.Steps[index + 1].State);
                                            <div class="pipeline-step-connector" style="@($"--line-color:{connectorColor};")"></div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </MudPaper>
    }
</div>

<MudDrawer @bind-Open="_drawerOpen"
           Anchor="Anchor.End"
           Variant="DrawerVariant.Temporary"
           Elevation="1"
           Width="520px">
    <MudStack Class="pa-4 drawer-section">
        @if (_activeDocument is not null)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">@_activeDocument.Name</MudText>
                    <MudText Typo="Typo.caption">@_activeDocument.RelativePath</MudText>
                </MudStack>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseDrawer" />
            </MudStack>

            <MudPaper Class="drawer-content-block" Elevation="0">
                <MudText Typo="Typo.caption" Class="mb-2">
                    Last updated @(_activeDocument.LastModifiedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))
                </MudText>
                <pre class="doc-pre">@_activeDocument.Content</pre>
            </MudPaper>
        }
        else if (_activeCard is not null)
        {
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Start">
                <MudStack Spacing="0">
                    <MudText Typo="Typo.h6">@_activeCard.Title</MudText>
                    <MudText Typo="Typo.caption">@_activeCard.LaneTitle</MudText>
                </MudStack>
                <MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="CloseDrawer" />
            </MudStack>

            <MudPaper Class="drawer-content-block" Elevation="0">
                <MudText Typo="Typo.caption" Class="mb-1">
                    Created @(_activeCard.Requirement.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))
                </MudText>
                <MudChip T="string"
                         Variant="Variant.Outlined"
                         Size="Size.Small"
                         Style="@($"border-color:{_activeCard.State.Color}; color:{_activeCard.State.Color};")">
                    @_activeCard.StatusLabel
                </MudChip>
                <MudText Typo="Typo.body2" Class="mt-3">@_activeCard.Description</MudText>
            </MudPaper>

            <MudPaper Class="drawer-content-block" Elevation="0">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Actions</MudText>
                <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1">
                    <MudButton Size="Size.Small"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Disabled="!CanAnalyze(_activeCard.Requirement.Status) || _runningRequirementId == _activeCard.Requirement.Id"
                               OnClick="() => StartAnalyzeAsync(_activeCard.Requirement.Id)">
                        Analyze
                    </MudButton>

                    <MudButton Size="Size.Small"
                               Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               Disabled="!CanDesign(_activeCard.Requirement.Status) || _runningRequirementId == _activeCard.Requirement.Id"
                               OnClick="() => StartDesignAsync(_activeCard.Requirement.Id)">
                        Design
                    </MudButton>

                    <MudButton Size="Size.Small"
                               Variant="Variant.Text"
                               Color="Color.Info"
                               Disabled="!CanPlan(_activeCard.Requirement.Status) || _runningRequirementId == _activeCard.Requirement.Id"
                               OnClick="() => StartPlanAsync(_activeCard.Requirement.Id)">
                        Plan
                    </MudButton>

                    @if (_activeCard.BacklogItem is not null)
                    {
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Filled"
                                   Color="Color.Success"
                                   Disabled="!CanImplement(_activeCard.BacklogItem) || _runningBacklogItemId == _activeCard.BacklogItem.Id"
                                   OnClick="() => StartImplementationAsync(_activeCard.BacklogItem.Id)">
                            Implement
                        </MudButton>
                    }
                </MudStack>
            </MudPaper>

            <MudPaper Class="drawer-content-block" Elevation="0">
                <MudText Typo="Typo.subtitle2" Class="mb-2">Workflow snapshot</MudText>
                <MudText Typo="Typo.body2">Requirement status: @_activeCard.Requirement.Status</MudText>
                <MudText Typo="Typo.body2">Priority: @_activeCard.Requirement.Priority</MudText>

                @if (_activeCard.WorkflowRun is not null)
                {
                    <MudText Typo="Typo.body2">Workflow: @_activeCard.WorkflowRun.WorkflowCode</MudText>
                    <MudText Typo="Typo.body2">Run stage: @_activeCard.WorkflowRun.CurrentStage</MudText>
                    <MudText Typo="Typo.body2">Run status: @_activeCard.WorkflowRun.Status</MudText>
                }

                @if (_activeCard.BacklogItem is not null)
                {
                    <MudText Typo="Typo.body2">Backlog order: @_activeCard.BacklogItem.PlanningOrder</MudText>
                    <MudText Typo="Typo.body2">Backlog status: @_activeCard.BacklogItem.Status</MudText>
                }
            </MudPaper>
        }
    </MudStack>
</MudDrawer>

@code {
    private static readonly IReadOnlyList<PipelineDefinition> _pipelineDefinitions =
    [
        new(LaneKeys.Requirement, "Requirement", Icons.Material.Filled.Flag),
        new(LaneKeys.Analysis, "Analysis", Icons.Material.Filled.Search),
        new(LaneKeys.Design, "Design", Icons.Material.Filled.Draw),
        new(LaneKeys.Planning, "Planning", Icons.Material.Filled.AccountTree),
        new(LaneKeys.Implementation, "Implementation", Icons.Material.Filled.Code),
        new(LaneKeys.Test, "Test", Icons.Material.Filled.FactCheck),
        new(LaneKeys.Review, "Review", Icons.Material.Filled.RateReview),
        new(LaneKeys.Deliver, "Deliver", Icons.Material.Filled.LocalShipping),
        new(LaneKeys.Documentation, "Documentation", Icons.Material.Filled.Description)
    ];

    private const string DefaultProfileCode = "dotnet-web-enterprise";
    private const string DefaultTargetCode = "dev";

    private readonly List<SolutionSummary> _solutions = [];
    private readonly List<RequirementRow> _requirements = [];
    private readonly List<BacklogRow> _backlog = [];
    private readonly List<WorkflowRunRow> _runs = [];
    private readonly List<SolutionDocumentSummary> _documents = [];

    private MudForm? _createSolutionForm;
    private Guid? _selectedSolutionId;
    private bool _loading;
    private bool _drawerOpen;
    private bool _documentsLoading;
    private bool _createSolutionPanelOpen;
    private bool _savingSolution;
    private Guid? _runningRequirementId;
    private Guid? _runningBacklogItemId;
    private string? _loadError;
    private string? _createSolutionMessage;
    private Severity _createSolutionMessageSeverity = Severity.Info;
    private RequirementStageCard? _activeCard;
    private SolutionDocumentContent? _activeDocument;
    private readonly SetupSolutionModel _solutionRequest = new();

    private IEnumerable<OverlayOption> OverlayOptions
        => _solutions.SelectMany(solution => solution.Targets.Select(target => new OverlayOption(solution, target)))
            .OrderBy(x => x.Label, StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _solutionRequest.ProfileCode = DefaultProfileCode;
        _solutionRequest.TargetCode = DefaultTargetCode;
        SelectedSolutionState.Changed += HandleSolutionChanged;
        await LoadSolutionsAsync();
        await EnsureSelectedSolutionAsync();
        await LoadCockpitAsync();
    }

    private async void HandleSolutionChanged()
    {
        _selectedSolutionId = SelectedSolutionState.Current?.SolutionId;
        await InvokeAsync(async () =>
        {
            await LoadDocumentsAsync();
            await LoadCockpitAsync();
        });
    }

    private async Task LoadSolutionsAsync()
    {
        var client = HttpClientFactory.CreateClient("api");
        _solutions.Clear();
        _solutions.AddRange(await client.GetFromJsonAsync<List<SolutionSummary>>("api/solutions") ?? []);
    }

    private async Task EnsureSelectedSolutionAsync()
    {
        if (SelectedSolutionState.Current is not null)
        {
            _selectedSolutionId = SelectedSolutionState.Current.SolutionId;
            return;
        }

        var first = _solutions.OrderBy(x => x.Name, StringComparer.OrdinalIgnoreCase).FirstOrDefault();
        if (first is not null)
        {
            _selectedSolutionId = first.SolutionId;
            SelectedSolutionState.SetCurrent(first, first.Targets.Count == 1 ? first.Targets[0].Id : first.Targets.FirstOrDefault()?.Id);
            await LoadDocumentsAsync();
        }
    }

    private async Task OnSolutionSelectionChangedAsync(Guid? solutionId)
    {
        _selectedSolutionId = solutionId;
        var selected = _solutions.FirstOrDefault(x => x.SolutionId == solutionId);
        SelectedSolutionState.SetCurrent(selected, selected?.Targets.Count == 1 ? selected.Targets[0].Id : selected?.Targets.FirstOrDefault()?.Id);
        await LoadDocumentsAsync();
        await LoadCockpitAsync();
    }

    private async Task LoadCockpitAsync()
    {
        _requirements.Clear();
        _backlog.Clear();
        _runs.Clear();
        _loadError = null;

        if (SelectedSolutionState.Current is null)
        {
            StateHasChanged();
            return;
        }

        _loading = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var solutionId = SelectedSolutionState.Current.SolutionId;
            _requirements.AddRange(await client.GetFromJsonAsync<List<RequirementRow>>($"api/solutions/{solutionId}/requirements") ?? []);
            _backlog.AddRange(await client.GetFromJsonAsync<List<BacklogRow>>($"api/backlog-items?solutionId={solutionId}") ?? []);
            _runs.AddRange(await client.GetFromJsonAsync<List<WorkflowRunRow>>($"api/workflow-runs?solutionId={solutionId}") ?? []);
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private async Task LoadDocumentsAsync()
    {
        _documents.Clear();

        if (SelectedSolutionState.Current is null)
        {
            return;
        }

        _documentsLoading = true;
        StateHasChanged();

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            _documents.AddRange(await client.GetFromJsonAsync<List<SolutionDocumentSummary>>($"api/solutions/{SelectedSolutionState.Current.SolutionId}/documents") ?? []);
        }
        finally
        {
            _documentsLoading = false;
            StateHasChanged();
        }
    }

    private RequirementPipelineViewModel BuildPipeline(RequirementRow requirement)
    {
        var requirementCard = new RequirementStageCard(
            LaneKeys.Requirement,
            "Requirement",
            requirement.Title,
            requirement.Description,
            requirement.CreatedAtUtc.ToLocalTime().ToString("dd MMM"),
            HumanizeRequirementStatus(requirement.Status),
            GetRequirementVisualState(requirement.Status),
            requirement,
            null,
            GetLatestRun(requirement.Id, null));

        var cards = new Dictionary<string, RequirementStageCard>(StringComparer.OrdinalIgnoreCase)
        {
            [LaneKeys.Requirement] = requirementCard
        };

        var requirementRunGroups = _runs
            .Where(x => x.RequirementId == requirement.Id)
            .GroupBy(x => x.WorkflowCode, StringComparer.OrdinalIgnoreCase)
            .ToDictionary(group => group.Key, group => group.OrderByDescending(x => x.StartedUtc).First(), StringComparer.OrdinalIgnoreCase);

        AddRequirementWorkflowCard(cards, LaneKeys.Analysis, requirementRunGroups, requirement, "analyze-request", "Analysis");
        AddRequirementWorkflowCard(cards, LaneKeys.Design, requirementRunGroups, requirement, "design-solution-change", "Design");
        AddRequirementWorkflowCard(cards, LaneKeys.Planning, requirementRunGroups, requirement, "plan-implementation", "Planning");

        var backlogItem = _backlog
            .Where(x => x.RequirementId == requirement.Id)
            .OrderBy(x => x.PlanningOrder)
            .ThenBy(x => x.CreatedUtc)
            .FirstOrDefault(x => !string.Equals(x.Status, "Validated", StringComparison.OrdinalIgnoreCase) && !string.Equals(x.Status, "Canceled", StringComparison.OrdinalIgnoreCase))
            ?? _backlog.Where(x => x.RequirementId == requirement.Id).OrderByDescending(x => x.PlanningOrder).FirstOrDefault();

        if (backlogItem is not null)
        {
            var implementationRun = GetLatestRun(requirement.Id, backlogItem.Id);

            cards[LaneKeys.Implementation] = new RequirementStageCard(
                LaneKeys.Implementation,
                "Implementation",
                backlogItem.Title,
                backlogItem.Description,
                backlogItem.CreatedUtc.ToLocalTime().ToString("dd MMM"),
                HumanizeBacklogStatus(backlogItem.Status),
                GetBacklogVisualState(backlogItem.Status),
                requirement,
                backlogItem,
                implementationRun);

            if (string.Equals(backlogItem.Status, "AwaitingValidation", StringComparison.OrdinalIgnoreCase))
            {
                cards[LaneKeys.Test] = new RequirementStageCard(
                    LaneKeys.Test,
                    "Test",
                    backlogItem.Title,
                    "Implementation is waiting for validation before the next slice can continue.",
                    (backlogItem.UpdatedUtc ?? backlogItem.CreatedUtc).ToLocalTime().ToString("dd MMM"),
                    "Awaiting validation",
                    GetBacklogVisualState(backlogItem.Status),
                    requirement,
                    backlogItem,
                    implementationRun);
            }
        }

        if (HasDocumentation(requirement))
        {
            cards[LaneKeys.Documentation] = new RequirementStageCard(
                LaneKeys.Documentation,
                "Documentation",
                "SDLC documents",
                "Solution SDLC documentation workspace is available for this requirement context.",
                requirement.CreatedAtUtc.ToLocalTime().ToString("dd MMM"),
                _documents.Count == 0 ? "Empty" : "Available",
                _documents.Count == 0 ? VisualStatePalette.Default : VisualStatePalette.Success,
                requirement,
                null,
                null);
        }

        var steps = _pipelineDefinitions
            .Select(definition => BuildPipelineStep(definition, cards, requirement, backlogItem))
            .ToList();

        return new RequirementPipelineViewModel(requirement, requirementCard.State, steps);
    }

    private void AddRequirementWorkflowCard(
        IDictionary<string, RequirementStageCard> row,
        string laneKey,
        IReadOnlyDictionary<string, WorkflowRunRow> runs,
        RequirementRow requirement,
        string workflowCode,
        string laneTitle)
    {
        if (!runs.TryGetValue(workflowCode, out var run))
        {
            return;
        }

        row[laneKey] = new RequirementStageCard(
            laneKey,
            laneTitle,
            requirement.Title,
            requirement.Description,
            run.StartedUtc.ToLocalTime().ToString("dd MMM"),
            HumanizeWorkflowStatus(run.Status),
            GetWorkflowVisualState(run.Status),
            requirement,
            null,
            run);
    }

    private RequirementPipelineStep BuildPipelineStep(
        PipelineDefinition definition,
        IReadOnlyDictionary<string, RequirementStageCard> cards,
        RequirementRow requirement,
        BacklogRow? backlogItem)
    {
        if (cards.TryGetValue(definition.Key, out var existing))
        {
            return new RequirementPipelineStep(definition.Key, definition.Title, definition.Icon, existing, false);
        }

        var placeholder = CreatePlaceholderCard(definition, requirement, backlogItem);
        return new RequirementPipelineStep(definition.Key, definition.Title, definition.Icon, placeholder, true);
    }

    private static RequirementStageCard CreatePlaceholderCard(PipelineDefinition definition, RequirementRow requirement, BacklogRow? backlogItem)
        => new(
            definition.Key,
            definition.Title,
            requirement.Title,
            BuildPlaceholderDescription(definition.Key),
            requirement.CreatedAtUtc.ToLocalTime().ToString("dd MMM"),
            "Unavailable",
            VisualStatePalette.Default,
            requirement,
            definition.Key == LaneKeys.Implementation || definition.Key == LaneKeys.Test ? backlogItem : null,
            null);

    private static string BuildPlaceholderDescription(string laneKey)
        => laneKey switch
        {
            LaneKeys.Requirement => "Requirement intake is the starting point for the workflow pipeline.",
            LaneKeys.Analysis => "Analysis has not started for this requirement.",
            LaneKeys.Design => "Design is not available yet for this requirement.",
            LaneKeys.Planning => "Planning is not available yet for this requirement.",
            LaneKeys.Implementation => "Implementation has not started for the active backlog item.",
            LaneKeys.Test => "Validation is not waiting on this requirement right now.",
            LaneKeys.Review => "Review is not available in the current workflow slice.",
            LaneKeys.Deliver => "Delivery is not available in the current workflow slice.",
            LaneKeys.Documentation => "Solution documentation is not available for this requirement yet.",
            _ => "This workflow step is not available."
        };

    private static string BuildPipelineTooltip(RequirementPipelineStep step)
        => $"{step.LaneTitle} - {step.Card.StatusLabel}";

    private WorkflowRunRow? GetLatestRun(Guid requirementId, Guid? backlogItemId)
        => _runs
            .Where(x => x.RequirementId == requirementId && x.BacklogItemId == backlogItemId)
            .OrderByDescending(x => x.StartedUtc)
            .FirstOrDefault();

    private bool HasDocumentation(RequirementRow requirement)
        => _documents.Count > 0 && !string.IsNullOrWhiteSpace(requirement.Status);

    private void OpenCard(RequirementStageCard card)
    {
        _activeDocument = null;
        _activeCard = card;
        _drawerOpen = true;
    }

    private async Task OpenDocumentAsync(SolutionDocumentSummary document)
    {
        if (SelectedSolutionState.Current is null)
        {
            return;
        }

        var client = HttpClientFactory.CreateClient("api");
        var path = Uri.EscapeDataString(document.RelativePath);
        _activeDocument = await client.GetFromJsonAsync<SolutionDocumentContent>($"api/solutions/{SelectedSolutionState.Current.SolutionId}/documents/content?path={path}");
        _activeCard = null;
        _drawerOpen = true;
    }

    private void CloseDrawer()
    {
        _drawerOpen = false;
        _activeCard = null;
        _activeDocument = null;
    }

    private void OpenCreateSolutionPanel()
    {
        _createSolutionMessage = null;
        _createSolutionPanelOpen = true;
        StateHasChanged();
    }

    private void CloseCreateSolutionPanel()
    {
        _createSolutionPanelOpen = false;
    }

    private async Task CreateSolutionAsync()
    {
        if (_createSolutionForm is not null)
        {
            await _createSolutionForm.Validate();
            if (!_createSolutionForm.IsValid)
            {
                return;
            }
        }

        _savingSolution = true;
        _createSolutionMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/workflow-runs/setup-solution", new
            {
                _solutionRequest.SolutionId,
                _solutionRequest.Name,
                _solutionRequest.Description,
                _solutionRequest.RepositoryPath,
                _solutionRequest.MainSolutionFile,
                _solutionRequest.ProfileCode,
                _solutionRequest.TargetCode,
                _solutionRequest.OverlayTargetId,
                _solutionRequest.RemoteRepositoryUrl,
                RequestedBy = "rui"
            });

            if (!response.IsSuccessStatusCode)
            {
                throw new InvalidOperationException(await ReadApiErrorAsync(response));
            }

            var createdSolutionName = _solutionRequest.Name;
            _createSolutionMessageSeverity = Severity.Success;
            _createSolutionMessage = "Solution setup workflow completed.";
            ResetSolutionForm();
            await LoadSolutionsAsync();

            var newSelection = _solutions.FirstOrDefault(x => string.Equals(x.Name, createdSolutionName, StringComparison.OrdinalIgnoreCase))
                ?? _solutions.OrderByDescending(x => x.CreatedUtc).FirstOrDefault();

            if (newSelection is not null)
            {
                _selectedSolutionId = newSelection.SolutionId;
                SelectedSolutionState.SetCurrent(newSelection, newSelection.Targets.Count == 1 ? newSelection.Targets[0].Id : newSelection.Targets.FirstOrDefault()?.Id);
            }

            _createSolutionPanelOpen = false;
            await LoadDocumentsAsync();
            await LoadCockpitAsync();
        }
        catch (Exception ex)
        {
            _createSolutionMessageSeverity = Severity.Error;
            _createSolutionMessage = ex.Message;
        }
        finally
        {
            _savingSolution = false;
        }
    }


    private static async Task<string> ReadApiErrorAsync(HttpResponseMessage response)
    {
        try
        {
            var error = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
            if (!string.IsNullOrWhiteSpace(error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return $"Request failed: {(int)response.StatusCode} {response.ReasonPhrase}".Trim();
    }

    private async Task StartAnalyzeAsync(Guid requirementId)
    {
        _runningRequirementId = requirementId;
        await StartRequirementWorkflowAsync("api/workflow-runs/analyze-request", requirementId);
    }

    private async Task StartDesignAsync(Guid requirementId)
    {
        _runningRequirementId = requirementId;
        await StartRequirementWorkflowAsync("api/workflow-runs/design-solution-change", requirementId);
    }

    private async Task StartPlanAsync(Guid requirementId)
    {
        _runningRequirementId = requirementId;
        await StartRequirementWorkflowAsync("api/workflow-runs/plan-implementation", requirementId);
    }

    private async Task StartRequirementWorkflowAsync(string endpoint, Guid requirementId)
    {
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync(endpoint, new { RequirementId = requirementId, RequestedBy = "rui" });
            response.EnsureSuccessStatusCode();
            await LoadCockpitAsync();
        }
        finally
        {
            _runningRequirementId = null;
        }
    }

    private async Task StartImplementationAsync(Guid backlogItemId)
    {
        _runningBacklogItemId = backlogItemId;
        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/workflow-runs/implement-solution-change", new { BacklogItemId = backlogItemId, RequestedBy = "rui" });
            response.EnsureSuccessStatusCode();
            await LoadCockpitAsync();
        }
        finally
        {
            _runningBacklogItemId = null;
        }
    }

    private static bool CanAnalyze(string status)
        => string.Equals(status, "submitted", StringComparison.OrdinalIgnoreCase)
           || string.Equals(status, "analysis-failed", StringComparison.OrdinalIgnoreCase);

    private static bool CanDesign(string status)
        => string.Equals(status, "analyzed", StringComparison.OrdinalIgnoreCase)
           || string.Equals(status, "design-failed", StringComparison.OrdinalIgnoreCase);

    private static bool CanPlan(string status)
        => string.Equals(status, "designed", StringComparison.OrdinalIgnoreCase)
           || string.Equals(status, "planning-failed", StringComparison.OrdinalIgnoreCase);

    private bool CanImplement(BacklogRow backlogItem)
    {
        if (!string.Equals(backlogItem.Status, "NotImplemented", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(backlogItem.Status, "ImplementationError", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (backlogItem.RequirementId is null)
        {
            return true;
        }

        var previousItems = _backlog
            .Where(x => x.RequirementId == backlogItem.RequirementId && x.PlanningOrder < backlogItem.PlanningOrder)
            .ToList();

        return previousItems.All(x => string.Equals(x.Status, "Validated", StringComparison.OrdinalIgnoreCase));
    }

    private static string HumanizeWorkflowStatus(int status)
        => status switch
        {
            1 => "Pending",
            2 => "Running",
            3 => "Done",
            4 => "Error",
            _ => "Unknown"
        };

    private static string HumanizeRequirementStatus(string status)
        => status.Replace("-", " ").Trim() switch
        {
            var value when string.Equals(value, "submitted", StringComparison.OrdinalIgnoreCase) => "Pending",
            var value when string.Equals(value, "under analysis", StringComparison.OrdinalIgnoreCase) => "Running",
            var value when string.Equals(value, "under design", StringComparison.OrdinalIgnoreCase) => "Running",
            var value when string.Equals(value, "under planning", StringComparison.OrdinalIgnoreCase) => "Running",
            var value when string.Equals(value, "under implementation", StringComparison.OrdinalIgnoreCase) => "Running",
            var value when string.Equals(value, "awaiting implementation validation", StringComparison.OrdinalIgnoreCase) => "Awaiting",
            var value when value.EndsWith("failed", StringComparison.OrdinalIgnoreCase) => "Error",
            var value when string.Equals(value, "canceled", StringComparison.OrdinalIgnoreCase) => "Canceled",
            var value => System.Globalization.CultureInfo.InvariantCulture.TextInfo.ToTitleCase(value)
        };

    private static string HumanizeBacklogStatus(string status)
        => status switch
        {
            "NotImplemented" => "Pending",
            "AwaitingValidation" => "Awaiting",
            "ImplementationError" => "Error",
            "Validated" => "Done",
            "Canceled" => "Canceled",
            _ => status
        };

    private static VisualState GetRequirementVisualState(string status)
    {
        var normalized = status.Replace("-", " ").Trim().ToLowerInvariant();

        if (normalized.Contains("failed") || normalized.Contains("canceled")) return VisualStatePalette.Error;
        if (normalized.Contains("awaiting")) return VisualStatePalette.Waiting;
        if (normalized.Contains("under")) return VisualStatePalette.Running;
        if (normalized.Contains("planned") || normalized.Contains("designed") || normalized.Contains("analyzed")) return VisualStatePalette.Success;

        return VisualStatePalette.Default;
    }

    private static VisualState GetBacklogVisualState(string status)
        => status switch
        {
            "AwaitingValidation" => VisualStatePalette.Waiting,
            "Validated" => VisualStatePalette.Success,
            "ImplementationError" => VisualStatePalette.Error,
            "Canceled" => VisualStatePalette.Error,
            _ => VisualStatePalette.Default
        };

    private static VisualState GetWorkflowVisualState(int status)
        => status switch
        {
            2 => VisualStatePalette.Running,
            3 => VisualStatePalette.Success,
            4 => VisualStatePalette.Error,
            _ => VisualStatePalette.Default
        };

    private static string GetConnectorColor(VisualState current, VisualState next)
    {
        if (next != VisualStatePalette.Default)
        {
            return next.Color;
        }

        return current != VisualStatePalette.Default ? current.Color : VisualStatePalette.Default.Color;
    }

    private Task OnOverlayTargetChangedAsync(Guid? targetId)
    {
        _solutionRequest.OverlayTargetId = targetId;
        return Task.CompletedTask;
    }

    private void ResetSolutionForm()
    {
        _solutionRequest.SolutionId = null;
        _solutionRequest.Name = string.Empty;
        _solutionRequest.Description = string.Empty;
        _solutionRequest.RepositoryPath = string.Empty;
        _solutionRequest.MainSolutionFile = string.Empty;
        _solutionRequest.ProfileCode = DefaultProfileCode;
        _solutionRequest.TargetCode = DefaultTargetCode;
        _solutionRequest.OverlayTargetId = null;
        _solutionRequest.RemoteRepositoryUrl = string.Empty;
    }

    public void Dispose()
    {
        SelectedSolutionState.Changed -= HandleSolutionChanged;
    }

    private static class LaneKeys
    {
        public const string Requirement = "requirement";
        public const string Analysis = "analysis";
        public const string Design = "design";
        public const string Planning = "planning";
        public const string Implementation = "implementation";
        public const string Test = "test";
        public const string Review = "review";
        public const string Deliver = "deliver";
        public const string Documentation = "documentation";
    }

