@page "/solutions"
@using System.Net.Http.Json
@using Iteration.Orchestrator.Cockpit.Models
@inject IHttpClientFactory HttpClientFactory
@inject Iteration.Orchestrator.Cockpit.Services.SelectedSolutionState SelectedSolutionState

<PageTitle>Solutions</PageTitle>

<MudText Typo="Typo.h4">Solutions</MudText>
<MudText Typo="Typo.body1" Class="mt-2 mb-4">
    Register or select a solution workspace for the SDLC orchestrator.
</MudText>

<MudGrid>
    <MudItem xs="12" md="5">
        <MudPaper Class="pa-4">
            <MudText Typo="Typo.h6" Class="mb-3">Setup solution</MudText>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <MudAlert Severity="@_messageSeverity" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                    @_message
                </MudAlert>
            }

            <MudForm @ref="_form">
                <MudTextField T="string" Label="Code" @bind-Value="_request.Code" Required="true" RequiredError="Code is required." />
                <MudTextField T="string" Label="Name" @bind-Value="_request.Name" Required="true" RequiredError="Name is required." />
                <MudTextField T="string" Label="Description" @bind-Value="_request.Description" Lines="3" />
                <MudTextField T="string" Label="Repository Path" @bind-Value="_request.RepositoryPath" Required="true" RequiredError="Repository path is required." />
                <MudTextField T="string" Label="Main Solution File" @bind-Value="_request.MainSolutionFile" Required="true" RequiredError="Main solution file is required." />
                <MudTextField T="string" Label="Profile Code" @bind-Value="_request.ProfileCode" Required="true" RequiredError="Profile code is required." />
                <MudTextField T="string" Label="Solution Overlay Code" @bind-Value="_request.SolutionOverlayCode" Required="true" RequiredError="Solution overlay code is required." />
                <MudTextField T="string" Label="Remote Repository URL" @bind-Value="_request.RemoteRepositoryUrl" />

                <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" Disabled="_saving" OnClick="CreateSolutionAsync">
                    Create / Setup solution
                </MudButton>
            </MudForm>
        </MudPaper>
    </MudItem>

    <MudItem xs="12" md="7">
        <MudPaper Class="pa-4">
            <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                <MudText Typo="Typo.h6">Available solutions</MudText>
                <MudButton Variant="Variant.Outlined" OnClick="LoadAsync">Refresh</MudButton>
            </MudStack>

            @if (_loading)
            {
                <MudProgressCircular Indeterminate="true" />
            }
            else if (!string.IsNullOrWhiteSpace(_loadError))
            {
                <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_loadError</MudAlert>
            }
            else if (_solutions.Count == 0)
            {
                <MudText Typo="Typo.body2">No solutions registered yet.</MudText>
            }
            else
            {
                <MudTable Items="_solutions" Dense="true" Hover="true">
                    <HeaderContent>
                        <MudTh>Code</MudTh>
                        <MudTh>Name</MudTh>
                        <MudTh>Profile</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh>Action</MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Code">@context.Code</MudTd>
                        <MudTd DataLabel="Name">@context.Name</MudTd>
                        <MudTd DataLabel="Profile">@context.ProfileCode</MudTd>
                        <MudTd DataLabel="Created">@context.CreatedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                        <MudTd DataLabel="Action">
                            <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" OnClick="() => SelectSolution(context)">
                                Select
                            </MudButton>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private MudForm? _form;
    private readonly List<SolutionSummary> _solutions = [];
    private readonly SetupSolutionModel _request = new();
    private bool _loading;
    private bool _saving;
    private string? _loadError;
    private string? _message;
    private Severity _messageSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _loadError = null;
        _solutions.Clear();

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            _solutions.AddRange(await client.GetFromJsonAsync<List<SolutionSummary>>("api/solutions") ?? []);
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private async Task CreateSolutionAsync()
    {
        if (_form is not null)
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                return;
            }
        }

        _saving = true;
        _message = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/workflow-runs/setup-solution", new
            {
                _request.SolutionId,
                _request.Code,
                _request.Name,
                _request.Description,
                _request.RepositoryPath,
                _request.MainSolutionFile,
                _request.ProfileCode,
                _request.SolutionOverlayCode,
                _request.RemoteRepositoryUrl,
                RequestedBy = "rui"
            });

            response.EnsureSuccessStatusCode();

            _messageSeverity = Severity.Success;
            _message = "Solution setup workflow completed.";
            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _messageSeverity = Severity.Error;
            _message = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private void SelectSolution(SolutionSummary solution)
    {
        SelectedSolutionState.SetCurrent(solution);

        _messageSeverity = Severity.Success;
        _message = $"Selected solution '{solution.Name}'.";
    }

    private void ResetForm()
    {
        _request.SolutionId = null;
        _request.Code = string.Empty;
        _request.Name = string.Empty;
        _request.Description = string.Empty;
        _request.RepositoryPath = string.Empty;
        _request.MainSolutionFile = string.Empty;
        _request.ProfileCode = string.Empty;
        _request.SolutionOverlayCode = string.Empty;
        _request.RemoteRepositoryUrl = string.Empty;
    }

    private sealed class SetupSolutionModel
    {
        public Guid? SolutionId { get; set; }
        public string Code { get; set; } = string.Empty;
        public string Name { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string RepositoryPath { get; set; } = string.Empty;
        public string MainSolutionFile { get; set; } = string.Empty;
        public string ProfileCode { get; set; } = string.Empty;
        public string SolutionOverlayCode { get; set; } = string.Empty;
        public string? RemoteRepositoryUrl { get; set; }
    }
}
