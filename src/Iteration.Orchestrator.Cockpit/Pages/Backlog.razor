@page "/requirements"
@using System.Net.Http.Json
@inject IHttpClientFactory HttpClientFactory
@implements IDisposable
@inject Iteration.Orchestrator.Cockpit.Services.SelectedSolutionState SelectedSolutionState

<PageTitle>Requirements</PageTitle>

<MudText Typo="Typo.h4">Requirements</MudText>
<MudText Typo="Typo.body1" Class="mt-2 mb-4">
    Requirements are the canonical intake object. Backlog remains downstream implementation work linked to requirements.
</MudText>

@if (SelectedSolutionState.CurrentTarget is null)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        Select a solution first on the Solutions page.
    </MudAlert>
}
else
{
    <MudGrid>
        <MudItem xs="12" md="5">
            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">Create requirement</MudText>

                @if (!string.IsNullOrWhiteSpace(_formMessage))
                {
                    <MudAlert Severity="@_formSeverity" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                        @_formMessage
                    </MudAlert>
                }

                <MudForm @ref="_form">
                    <MudTextField T="string" Label="Title" @bind-Value="_request.Title" Required="true" RequiredError="Title is required." />
                    <MudTextField T="string" Label="Description" Lines="5" @bind-Value="_request.Description" Required="true" RequiredError="Description is required." />
                    <MudSelect T="string" Label="Priority" @bind-Value="_request.Priority">
                        <MudSelectItem Value="@("low")">Low</MudSelectItem>
                        <MudSelectItem Value="@("medium")">Medium</MudSelectItem>
                        <MudSelectItem Value="@("high")">High</MudSelectItem>
                        <MudSelectItem Value="@("critical")">Critical</MudSelectItem>
                    </MudSelect>

                    <MudButton Variant="Variant.Filled" Color="Color.Primary" Class="mt-4" Disabled="_saving" OnClick="CreateRequirementAsync">
                        Save requirement
                    </MudButton>
                </MudForm>
            </MudPaper>
        </MudItem>

        <MudItem xs="12" md="7">
            <MudPaper Class="pa-4 mb-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-3">
                    <MudText Typo="Typo.h6">Requirements</MudText>
                    <MudButton Variant="Variant.Outlined" OnClick="() => LoadAsync()">Refresh</MudButton>
                </MudStack>

                @if (_loading)
                {
                    <MudProgressCircular Indeterminate="true" />
                }
                else if (!string.IsNullOrWhiteSpace(_loadError))
                {
                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined">@_loadError</MudAlert>
                }
                else if (_requirements.Count == 0)
                {
                    <MudText Typo="Typo.body2">No requirements created yet.</MudText>
                }
                else
                {
                    <MudTable Items="_requirements" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh>Title</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Priority</MudTh>
                            <MudTh>Created</MudTh>
                            <MudTh>Action</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Title">@context.Title</MudTd>
                            <MudTd DataLabel="Status">@context.Status</MudTd>
                            <MudTd DataLabel="Priority">@context.Priority</MudTd>
                            <MudTd DataLabel="Created">@context.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                            <MudTd DataLabel="Action">
                                <MudStack Row="true" Spacing="1">
                                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary" Disabled="_runningRequirementId == context.Id || !CanAnalyze(context)" OnClick="() => StartAnalyzeAsync(context.Id)">
                                        Analyze
                                    </MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary" Disabled="_runningRequirementId == context.Id || !CanDesign(context)" OnClick="() => StartDesignAsync(context.Id)">
                                        Design
                                    </MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Text" Color="Color.Info" Disabled="_runningRequirementId == context.Id || !CanPlan(context)" OnClick="() => StartPlanAsync(context.Id)">
                                        Plan
                                    </MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Filled" Color="Color.Success" Disabled="_mutatingRequirementId == context.Id || !CanCommitRequirement(context)" OnClick="() => CommitRequirementAsync(context.Id)">
                                        Commit
                                    </MudButton>
                                    <MudButton Size="Size.Small" Variant="Variant.Outlined" Color="Color.Error" Disabled="_mutatingRequirementId == context.Id || !CanCancelRequirement(context)" OnClick="() => CancelRequirementAsync(context.Id)">
                                        Cancel
                                    </MudButton>
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>

            <MudPaper Class="pa-4 mb-4">
                <MudText Typo="Typo.h6" Class="mb-3">Planned backlog</MudText>
                @if (_backlog.Count == 0)
                {
                    <MudText Typo="Typo.body2">No backlog items generated yet.</MudText>
                }
                else
                {
                    <MudTable Items="_backlog" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh>Order</MudTh>
                            <MudTh>Requirement</MudTh>
                            <MudTh>Title</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Action</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Order">@context.PlanningOrder</MudTd>
                            <MudTd DataLabel="Requirement">@GetRequirementTitle(context.RequirementId)</MudTd>
                            <MudTd DataLabel="Title">@context.Title</MudTd>
                            <MudTd DataLabel="Status">@context.Status</MudTd>
                            <MudTd DataLabel="Action">
                                <MudButton Size="Size.Small"
                                           Variant="Variant.Filled"
                                           Color="Color.Success"
                                           Disabled="_runningBacklogItemId == context.Id || !CanImplement(context)"
                                           OnClick="() => StartImplementationAsync(context.Id)">
                                    Implement
                                </MudButton>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>

            <MudPaper Class="pa-4">
                <MudText Typo="Typo.h6" Class="mb-3">Workflow history</MudText>
                @if (_runs.Count == 0)
                {
                    <MudText Typo="Typo.body2">No workflow runs recorded yet.</MudText>
                }
                else
                {
                    <MudTable Items="_runs" Dense="true" Hover="true">
                        <HeaderContent>
                            <MudTh>Workflow</MudTh>
                            <MudTh>Status</MudTh>
                            <MudTh>Stage</MudTh>
                            <MudTh>Started</MudTh>
                            <MudTh>Action</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd DataLabel="Workflow">@context.WorkflowCode</MudTd>
                            <MudTd DataLabel="Status">@HumanizeWorkflowStatus(context.Status)</MudTd>
                            <MudTd DataLabel="Stage">@context.CurrentStage</MudTd>
                            <MudTd DataLabel="Started">@context.StartedUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</MudTd>
                            <MudTd DataLabel="Action">
                                <MudStack Row="true" Spacing="1">
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Filled"
                                               Color="Color.Warning"
                                               Disabled="!CanValidate(context) || _mutatingWorkflowRunId == context.Id"
                                               OnClick="() => ValidateWorkflowRunAsync(context.Id)">
                                        Validate
                                    </MudButton>
                                    <MudButton Size="Size.Small"
                                               Variant="Variant.Outlined"
                                               Color="Color.Error"
                                               Disabled="!CanCancel(context) || _mutatingWorkflowRunId == context.Id"
                                               OnClick="() => CancelWorkflowRunAsync(context.Id)">
                                        Cancel
                                    </MudButton>
                                </MudStack>
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                }
            </MudPaper>
        </MudItem>
    </MudGrid>
}

@code {
    private MudForm? _form;
    private readonly CreateRequirementModel _request = new();
    private readonly List<RequirementRow> _requirements = [];
    private readonly List<BacklogRow> _backlog = [];
    private readonly List<WorkflowRunRow> _runs = [];
    private bool _loading;
    private bool _saving;
    private Guid? _runningRequirementId;
    private Guid? _runningBacklogItemId;
    private Guid? _mutatingWorkflowRunId;
    private Guid? _mutatingRequirementId;
    private bool _refreshInProgress;
    private long _refreshVersion;
    private string? _lastSnapshot;
    private CancellationTokenSource? _pollingCts;
    private Task? _pollingTask;
    private string? _loadError;
    private string? _formMessage;
    private Severity _formSeverity = Severity.Info;

    protected override async Task OnInitializedAsync()
    {
        ResetForm();
        SelectedSolutionState.Changed += HandleSolutionChanged;
        await LoadAsync();
    }

    private async void HandleSolutionChanged()
    {
        StopPolling();
        await InvokeAsync(() => LoadAsync());
    }

    private async Task LoadAsync(bool showLoading = true)
    {
        if (_refreshInProgress)
        {
            return;
        }

        var refreshVersion = Interlocked.Increment(ref _refreshVersion);
        _refreshInProgress = true;
        var shouldRender = false;
        var previousLoadError = _loadError;
        _loadError = null;

        if (SelectedSolutionState.CurrentTarget is null)
        {
            if (_requirements.Count > 0 || _backlog.Count > 0 || _runs.Count > 0 || _lastSnapshot is not null)
            {
                _requirements.Clear();
                _backlog.Clear();
                _runs.Clear();
                _lastSnapshot = null;
                shouldRender = true;
            }

            _loading = false;
            EnsurePollingState();
            if (shouldRender || !string.Equals(previousLoadError, _loadError, StringComparison.Ordinal))
            {
                StateHasChanged();
            }

            _refreshInProgress = false;
            return;
        }

        if (showLoading && !_loading)
        {
            _loading = true;
            shouldRender = true;
        }

        if (shouldRender)
        {
            StateHasChanged();
        }

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var targetSolutionId = SelectedSolutionState.CurrentTarget?.Id;
            if (!targetSolutionId.HasValue)
            {
                return;
            }

            var requirements = await client.GetFromJsonAsync<List<RequirementRow>>($"api/solution-targets/{targetSolutionId.Value}/requirements") ?? [];
            var backlog = await client.GetFromJsonAsync<List<BacklogRow>>($"api/backlog-items?targetSolutionId={targetSolutionId.Value}") ?? [];
            var runs = await client.GetFromJsonAsync<List<WorkflowRunRow>>($"api/workflow-runs?targetSolutionId={targetSolutionId.Value}") ?? [];

            if (refreshVersion != _refreshVersion || SelectedSolutionState.CurrentTarget?.Id != targetSolutionId.Value)
            {
                return;
            }

            var snapshot = BuildSnapshot(targetSolutionId.Value, requirements, backlog, runs);
            if (!string.Equals(snapshot, _lastSnapshot, StringComparison.Ordinal))
            {
                _requirements.Clear();
                _requirements.AddRange(requirements);
                _backlog.Clear();
                _backlog.AddRange(backlog);
                _backlog.Sort((left, right) =>
                {
                    var requirementCompare = Nullable.Compare(left.RequirementId, right.RequirementId);
                    return requirementCompare != 0 ? requirementCompare : left.PlanningOrder.CompareTo(right.PlanningOrder);
                });
                _runs.Clear();
                _runs.AddRange(runs);
                _lastSnapshot = snapshot;
                shouldRender = true;
            }

            if (!string.Equals(previousLoadError, _loadError, StringComparison.Ordinal))
            {
                shouldRender = true;
            }
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
            shouldRender = !string.Equals(previousLoadError, _loadError, StringComparison.Ordinal);
        }
        finally
        {
            if (_loading)
            {
                _loading = false;
                shouldRender = true;
            }

            _refreshInProgress = false;
            EnsurePollingState();
            if (shouldRender)
            {
                StateHasChanged();
            }
        }
    }


    private void EnsurePollingState()
    {
        if (_runs.Any(x => x.Status is 1 or 2 or 6))
        {
            StartPolling();
            return;
        }

        StopPolling();
    }

    private void StartPolling()
    {
        if (_pollingTask is { IsCompleted: false })
        {
            return;
        }

        _pollingCts?.Cancel();
        _pollingCts?.Dispose();
        _pollingCts = new CancellationTokenSource();
        _pollingTask = MonitorAsync(_pollingCts.Token);
    }

    private void StopPolling()
    {
        _pollingCts?.Cancel();
        _pollingCts?.Dispose();
        _pollingCts = null;
        _pollingTask = null;
    }

    private async Task MonitorAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));

        try
        {
            while (await timer.WaitForNextTickAsync(ct))
            {
                if (_refreshInProgress || SelectedSolutionState.CurrentTarget is null)
                {
                    continue;
                }

                await InvokeAsync(() => LoadAsync(showLoading: false));
            }
        }
        catch (OperationCanceledException)
        {
        }
    }

    private static async Task<string> ReadApiErrorAsync(HttpResponseMessage response)
    {
        try
        {
            var error = await response.Content.ReadFromJsonAsync<ApiErrorResponse>();
            if (!string.IsNullOrWhiteSpace(error?.Message))
            {
                return error.Message;
            }
        }
        catch
        {
        }

        return $"Request failed: {(int)response.StatusCode} {response.ReasonPhrase}".Trim();
    }

    private async Task CreateRequirementAsync()
    {
        if (SelectedSolutionState.CurrentTarget is null)
        {
            return;
        }

        if (_form is not null)
        {
            await _form.Validate();
            if (!_form.IsValid)
            {
                return;
            }
        }

        _saving = true;
        _formMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/requirements", new
            {
                TargetSolutionId = SelectedSolutionState.CurrentTarget.Id,
                _request.Title,
                _request.Description,
                RequirementType = "functional",
                Source = "user",
                _request.Priority
            });
            response.EnsureSuccessStatusCode();

            _formSeverity = Severity.Success;
            _formMessage = "Requirement created.";
            ResetForm();
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formSeverity = Severity.Error;
            _formMessage = ex.Message;
        }
        finally
        {
            _saving = false;
        }
    }

    private async Task StartAnalyzeAsync(Guid requirementId)
    {
        _runningRequirementId = requirementId;
        _formMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/workflow-runs/analyze-request", new
            {
                RequirementId = requirementId,
                RequestedBy = "rui"
            });
            response.EnsureSuccessStatusCode();

            _formSeverity = Severity.Success;
            _formMessage = "Analyze workflow started.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formSeverity = Severity.Error;
            _formMessage = ex.Message;
        }
        finally
        {
            _runningRequirementId = null;
        }
    }

    private async Task StartDesignAsync(Guid requirementId)
    {
        _runningRequirementId = requirementId;
        _formMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/workflow-runs/design-solution-change", new
            {
                RequirementId = requirementId,
                RequestedBy = "rui"
            });
            response.EnsureSuccessStatusCode();

            _formSeverity = Severity.Success;
            _formMessage = "Design workflow started.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formSeverity = Severity.Error;
            _formMessage = ex.Message;
        }
        finally
        {
            _runningRequirementId = null;
        }
    }

    private async Task StartPlanAsync(Guid requirementId)
    {
        _runningRequirementId = requirementId;
        _formMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/workflow-runs/plan-implementation", new
            {
                RequirementId = requirementId,
                RequestedBy = "rui"
            });
            response.EnsureSuccessStatusCode();

            _formSeverity = Severity.Success;
            _formMessage = "Plan workflow started.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formSeverity = Severity.Error;
            _formMessage = ex.Message;
        }
        finally
        {
            _runningRequirementId = null;
        }
    }

    private async Task StartImplementationAsync(Guid backlogItemId)
    {
        _runningBacklogItemId = backlogItemId;
        _formMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/workflow-runs/implement-solution-change", new
            {
                BacklogItemId = backlogItemId,
                RequestedBy = "rui"
            });
            response.EnsureSuccessStatusCode();

            _formSeverity = Severity.Success;
            _formMessage = "Implementation workflow started.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formSeverity = Severity.Error;
            _formMessage = ex.Message;
        }
        finally
        {
            _runningBacklogItemId = null;
        }
    }

    private bool CanAnalyze(RequirementRow row)
        => string.Equals(row.Status, "Pending", StringComparison.OrdinalIgnoreCase)
            && !HasBlockingRun(row.Id, null, "analyze-request");

    private bool CanDesign(RequirementRow row)
        => string.Equals(row.Status, "Analyzed", StringComparison.OrdinalIgnoreCase)
            && !HasBlockingRun(row.Id, null, "design-solution-change");

    private bool CanPlan(RequirementRow row)
        => string.Equals(row.Status, "Designed", StringComparison.OrdinalIgnoreCase)
            && !HasBlockingRun(row.Id, null, "plan-implementation");

    private bool CanCommitRequirement(RequirementRow row)
        => string.Equals(row.Status, "PendingCommit", StringComparison.OrdinalIgnoreCase)
            && !HasAnyBlockingRun(row.Id);

    private bool CanCancelRequirement(RequirementRow row)
        => !string.Equals(row.Status, "Completed", StringComparison.OrdinalIgnoreCase)
            && !string.Equals(row.Status, "Cancelled", StringComparison.OrdinalIgnoreCase)
            && !HasAnyBlockingRun(row.Id);

    private bool CanImplement(BacklogRow row)
    {
        if (row.RequirementId.HasValue
            && !string.Equals(GetRequirementStatus(row.RequirementId), "Planned", StringComparison.OrdinalIgnoreCase))
        {
            return false;
        }

        if (!(string.Equals(row.Status, "NotImplemented", StringComparison.OrdinalIgnoreCase)
            || string.Equals(row.Status, "ImplementationError", StringComparison.OrdinalIgnoreCase)))
        {
            return false;
        }

        var previousItems = _backlog
            .Where(x => x.RequirementId == row.RequirementId && x.PlanningOrder < row.PlanningOrder)
            .ToList();

        return previousItems.All(x => string.Equals(x.Status, "Validated", StringComparison.OrdinalIgnoreCase)
            || string.Equals(x.Status, "Canceled", StringComparison.OrdinalIgnoreCase))
            && !HasBlockingRun(row.RequirementId, row.Id, "implement-solution-change");
    }

    private static bool CanValidate(WorkflowRunRow run)
        => run.Status == 6;

    private static bool CanCancel(WorkflowRunRow run)
        => run.Status is 1 or 4 or 6;

    private bool HasBlockingRun(Guid? requirementId, Guid? backlogItemId, string workflowCode)
        => _runs.Any(x =>
            x.RequirementId == requirementId
            && x.BacklogItemId == backlogItemId
            && string.Equals(x.WorkflowCode, workflowCode, StringComparison.OrdinalIgnoreCase)
            && x.Status is 1 or 2 or 6);

    private bool HasAnyBlockingRun(Guid requirementId)
        => _runs.Any(x => x.RequirementId == requirementId && x.Status is 1 or 2 or 6);

    private string GetRequirementStatus(Guid? requirementId)
        => _requirements.FirstOrDefault(x => x.Id == requirementId)?.Status ?? string.Empty;

    private async Task CommitRequirementAsync(Guid requirementId)
    {
        _mutatingRequirementId = requirementId;
        _formMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsync($"api/requirements/{requirementId}/commit", null);
            response.EnsureSuccessStatusCode();

            _formSeverity = Severity.Success;
            _formMessage = "Requirement committed.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formSeverity = Severity.Error;
            _formMessage = ex.Message;
        }
        finally
        {
            _mutatingRequirementId = null;
        }
    }

    private async Task CancelRequirementAsync(Guid requirementId)
    {
        _mutatingRequirementId = requirementId;
        _formMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsync($"api/requirements/{requirementId}/cancel", null);
            response.EnsureSuccessStatusCode();

            _formSeverity = Severity.Success;
            _formMessage = "Requirement cancelled.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formSeverity = Severity.Error;
            _formMessage = ex.Message;
        }
        finally
        {
            _mutatingRequirementId = null;
        }
    }

    private async Task ValidateWorkflowRunAsync(Guid workflowRunId)
    {
        _mutatingWorkflowRunId = workflowRunId;
        _formMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/workflow-runs/validate", new { WorkflowRunId = workflowRunId });
            response.EnsureSuccessStatusCode();

            _formSeverity = Severity.Success;
            _formMessage = "Workflow run validated.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formSeverity = Severity.Error;
            _formMessage = ex.Message;
        }
        finally
        {
            _mutatingWorkflowRunId = null;
        }
    }

    private async Task CancelWorkflowRunAsync(Guid workflowRunId)
    {
        _mutatingWorkflowRunId = workflowRunId;
        _formMessage = null;

        try
        {
            var client = HttpClientFactory.CreateClient("api");
            var response = await client.PostAsJsonAsync("api/workflow-runs/cancel", new
            {
                WorkflowRunId = workflowRunId,
                TerminateRequirementLifecycle = false,
                Reason = "Cancelled from cockpit"
            });
            response.EnsureSuccessStatusCode();

            _formSeverity = Severity.Success;
            _formMessage = "Workflow run cancelled.";
            await LoadAsync();
        }
        catch (Exception ex)
        {
            _formSeverity = Severity.Error;
            _formMessage = ex.Message;
        }
        finally
        {
            _mutatingWorkflowRunId = null;
        }
    }

    private static string HumanizeWorkflowStatus(int status)
        => status switch
        {
            1 => "Pending",
            2 => "Running",
            3 => "Validated",
            4 => "Error",
            5 => "Cancelled",
            6 => "Awaiting Validation",
            _ => "Unknown"
        };

    private static string BuildSnapshot(
        Guid targetSolutionId,
        IReadOnlyList<RequirementRow> requirements,
        IReadOnlyList<BacklogRow> backlog,
        IReadOnlyList<WorkflowRunRow> runs)
    {
        var requirementPart = string.Join("|", requirements
            .OrderBy(x => x.Id)
            .Select(x => $"{x.Id}:{x.Status}"));

        var backlogPart = string.Join("|", backlog
            .OrderBy(x => x.Id)
            .Select(x => $"{x.Id}:{x.RequirementId}:{x.Status}"));

        var runPart = string.Join("|", runs
            .OrderBy(x => x.Id)
            .Select(x => $"{x.Id}:{x.RequirementId}:{x.BacklogItemId}:{x.WorkflowCode}:{x.Status}"));

        return $"{targetSolutionId}||{requirementPart}||{backlogPart}||{runPart}";
    }

    private string GetRequirementTitle(Guid? requirementId)
        => _requirements.FirstOrDefault(x => x.Id == requirementId)?.Title ?? "-";

    private void ResetForm()
    {
        _request.Title = string.Empty;
        _request.Description = string.Empty;
        _request.Priority = "medium";
    }

    public void Dispose()
    {
        StopPolling();
        SelectedSolutionState.Changed -= HandleSolutionChanged;
    }

    private sealed class CreateRequirementModel
    {
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
        public string Priority { get; set; } = "medium";
    }

    private sealed class RequirementRow
    {
        public Guid Id { get; set; }
        public string Title { get; set; } = string.Empty;
        public string Description { get; set; } = string.Empty;
