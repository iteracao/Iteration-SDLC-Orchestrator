@using Iteration.Orchestrator.Cockpit.Models

@if (IsOpen && (ActiveWorkflowArtifact is not null || ActiveWorkflowLog is not null))
{
    <div class="inspect-backdrop" @onclick="Close"></div>
    <div class="inspect-shell">
        <MudPaper Class="inspect-panel" Elevation="8">
            <div class="inspect-toolbar">
                <MudStack Spacing="0"><MudText Typo="Typo.h6">@Title</MudText><MudText Typo="Typo.caption" Class="inspect-meta">@Subtitle</MudText></MudStack>
                <MudStack Row="true" Spacing="1" AlignItems="AlignItems.Center"><MudButton Size="Size.Small" Variant="Variant.Outlined" OnClick="Copy">Copy</MudButton><MudIconButton Icon="@Icons.Material.Filled.Close" OnClick="Close" /></MudStack>
            </div>
            <div class="inspect-body">
                @if (ActiveWorkflowLog is not null)
                {
                    @if (ActiveWorkflowLog.ArtifactFiles.Count > 0)
                    {
                        <MudStack Row="true" Wrap="Wrap.Wrap" Spacing="1" Class="mb-3">
                            @foreach (var artifactFile in ActiveWorkflowLog.ArtifactFiles)
                            {
                                <MudChip T="string" Variant="Variant.Outlined" Size="Size.Small" OnClick="() => OpenArtifact.InvokeAsync(artifactFile)">@artifactFile</MudChip>
                            }
                        </MudStack>
                    }
                    @if (ActiveWorkflowLog.IsUnavailable && !string.IsNullOrWhiteSpace(ActiveWorkflowLog.Message)) { <p class="inspect-message">@ActiveWorkflowLog.Message</p> }
                    else { <pre class="doc-pre">@ActiveWorkflowLog.Content</pre> }
                }
                else if (ActiveWorkflowArtifact is not null)
                {
                    @if (ActiveWorkflowArtifact.IsUnavailable && !string.IsNullOrWhiteSpace(ActiveWorkflowArtifact.Message)) { <p class="inspect-message">@ActiveWorkflowArtifact.Message</p> }
                    else { <pre class="doc-pre">@ActiveWorkflowArtifact.Content</pre> }
                }
            </div>
        </MudPaper>
    </div>
}

@code {
    [Parameter] public bool IsOpen { get; set; }
    [Parameter] public WorkflowArtifactContent? ActiveWorkflowArtifact { get; set; }
    [Parameter] public WorkflowLogContent? ActiveWorkflowLog { get; set; }
    [Parameter] public string Title { get; set; } = string.Empty;
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public EventCallback Copy { get; set; }
    [Parameter] public EventCallback Close { get; set; }
    [Parameter] public EventCallback<string> OpenArtifact { get; set; }
}
